@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<IT15_SOWCS.Models.Users> UserManager
@inject IT15_SOWCS.Data.AppDbContext DbContext
@{
    var user = await UserManager.GetUserAsync(User);
    var rawRole = user?.Role ?? "user";
    var employeeProfile = user == null
        ? null
        : await DbContext.Employees
            .Where(employee => employee.user_id == user.Id)
            .Select(employee => new { employee.full_name, employee.employee_role })
            .FirstOrDefaultAsync();
    var rawEmployeeRole = employeeProfile?.employee_role ?? string.Empty;
    var displayName = !string.IsNullOrWhiteSpace(employeeProfile?.full_name)
        ? employeeProfile.full_name
        : !string.IsNullOrWhiteSpace(user?.FullName)
            ? user!.FullName
            : (user?.Email ?? "User");
    var initials = string.Concat(
        displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]))
            .Take(2));
    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }

    var normalizedRole = rawRole.Trim().ToLowerInvariant();
    var normalizedEmployeeRole = rawEmployeeRole.Trim().ToLowerInvariant();
    var isSuperAdmin = normalizedRole == "superadmin";
    var isHrManager = normalizedEmployeeRole == "hr manager" || normalizedEmployeeRole == "hr";
    var isProjectManager = normalizedEmployeeRole == "manager" || normalizedEmployeeRole == "project manager";
    var isRegularEmployee = normalizedRole == "user" && !isHrManager && !isProjectManager;

    var role = rawRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase)
        ? "Super Admin"
        : !string.IsNullOrWhiteSpace(rawEmployeeRole)
            ? rawEmployeeRole
            : rawRole.Equals("user", StringComparison.OrdinalIgnoreCase)
                ? "Employee"
                : string.IsNullOrWhiteSpace(rawRole)
                    ? "User"
                    : char.ToUpperInvariant(rawRole[0]) + rawRole.Substring(1);

    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

    string IsActive(string controller, string action)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
               string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
               ? "active" : "";
    }
}

