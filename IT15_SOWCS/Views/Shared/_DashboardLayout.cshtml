@using Microsoft.AspNetCore.Identity
@inject SignInManager<IT15_SOWCS.Models.Users> signInManager
@{
    var topController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var topAction = ViewContext.RouteData.Values["Action"]?.ToString();

    string? topHeaderTitle = null;

    if (string.Equals(topController, "Dashboard", StringComparison.OrdinalIgnoreCase))
    {
        topHeaderTitle = "Dashboard";
    }
    else if (string.Equals(topController, "Projects", StringComparison.OrdinalIgnoreCase) &&
             string.Equals(topAction, "ProjectDetail", StringComparison.OrdinalIgnoreCase))
    {
        topHeaderTitle = "Project Details";
    }
    else if (string.Equals(topController, "Profile", StringComparison.OrdinalIgnoreCase) &&
             string.Equals(topAction, "Profile", StringComparison.OrdinalIgnoreCase))
    {
        topHeaderTitle = "Profile Settings";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Syncora</title>
    <link rel="icon" type="image/png" href="~/images/SOWCS.png" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="d-flex">
        @await Html.PartialAsync("_Sidebar")
        <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

        <div class="flex-grow-1 d-flex flex-column" style="min-height: 100vh;">
           
            <nav class="navbar navbar-expand-sm navbar-white bg-white border-bottom px-4 py-3">
                <div class="container-fluid">
                    <div class="d-flex align-items-center gap-3">
                        <button type="button" id="topbarSidebarToggle" class="topbar-sidebar-toggle" aria-label="Toggle sidebar">
                            <i class="bi bi-list"></i>
                        </button>
                        @if (!string.IsNullOrWhiteSpace(topHeaderTitle))
                        {
                            <div class="fw-semibold text-dark fs-5">@topHeaderTitle</div>
                        }
                    </div>
                    @await Html.PartialAsync("_TopNavActions")
                </div>
            </nav>

            <main role="main" class="dashboard-main p-4 flex-grow-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const sidebar = document.getElementById("sidebar");
        const headerToggle = document.getElementById("topbarSidebarToggle");
        const sidebarBackdrop = document.getElementById("sidebarBackdrop");
        const mobileQuery = window.matchMedia("(max-width: 992px)");

        if (!sidebar || !headerToggle || !sidebarBackdrop) {
            return;
        }

        function setDesktopState() {
            const savedState = localStorage.getItem("sidebar-collapsed");
            if (savedState === "true") {
                sidebar.classList.add("collapsed");
            } else {
                sidebar.classList.remove("collapsed");
            }
            sidebar.classList.remove("mobile-open");
            document.body.classList.remove("sidebar-mobile-open");
        }

        function setMobileState() {
            sidebar.classList.remove("collapsed");
            sidebar.classList.remove("mobile-open");
            document.body.classList.remove("sidebar-mobile-open");
        }

        function applySidebarMode() {
            if (mobileQuery.matches) {
                setMobileState();
            } else {
                setDesktopState();
            }
        }

        headerToggle.addEventListener("click", function () {
            if (mobileQuery.matches) {
                const willOpen = !sidebar.classList.contains("mobile-open");
                sidebar.classList.toggle("mobile-open", willOpen);
                document.body.classList.toggle("sidebar-mobile-open", willOpen);
            } else {
                sidebar.classList.toggle("collapsed");
                localStorage.setItem("sidebar-collapsed", sidebar.classList.contains("collapsed").toString());
            }
        });

        sidebarBackdrop.addEventListener("click", function () {
            sidebar.classList.remove("mobile-open");
            document.body.classList.remove("sidebar-mobile-open");
        });

        window.addEventListener("resize", applySidebarMode);
        applySidebarMode();
    });
</script>




