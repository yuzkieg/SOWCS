@model IT15_SOWCS.ViewModels.UserManagementPageViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IT15_SOWCS.Models.Users> UserManager
@{
    Layout = "_UserManagementLayout";
    ViewData["Title"] = "User Management";
    var selectedFilter = (Model.SelectedFilter ?? "all").ToLowerInvariant();
    var searchQuery = string.IsNullOrWhiteSpace(Model.Search) ? null : Model.Search;
    var currentUser = await UserManager.GetUserAsync(User);
    var canArchive = string.Equals(currentUser?.Role, "superadmin", StringComparison.OrdinalIgnoreCase);
}

<div class="um-container">
    <div class="um-header">
        <div class="um-title">
            <h2>User Management</h2>
            <p>Manage system users and access</p>
        </div>
        <button class="btn-invite" data-bs-toggle="modal" data-bs-target="#inviteUserModal">
            <i class="bi bi-person-plus"></i> Invite User
        </button>
    </div>

    @if (TempData["UserManagementError"] is string userManagementError)
    {
        <div class="alert alert-danger">@userManagementError</div>
    }

    <div class="um-stats-grid">
        <a class="stat-card stat-filter-card @(selectedFilter == "all" ? "active" : string.Empty)"
           data-um-filter-card="all"
           asp-action="UserManagement"
           asp-route-filter="all"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-blue">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value" id="umTotalUsersCount">@Model.TotalUsersCount</span>
                <span class="stat-label">Total Users</span>
            </div>
        </a>
        <a class="stat-card stat-filter-card @(selectedFilter == "admins" ? "active" : string.Empty)"
           data-um-filter-card="admins"
           asp-action="UserManagement"
           asp-route-filter="admins"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-purple">
                <i class="bi bi-shield-lock"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value" id="umAdminCount">@Model.AdminCount</span>
                <span class="stat-label">Admins</span>
            </div>
        </a>
        <a class="stat-card stat-filter-card @(selectedFilter == "employees" ? "active" : string.Empty)"
           data-um-filter-card="employees"
           asp-action="UserManagement"
           asp-route-filter="employees"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-green">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value" id="umActiveEmployeeCount">@Model.ActiveEmployeeCount</span>
                <span class="stat-label">Active Employees</span>
            </div>
        </a>
    </div>

    <form id="umStatusTokenForm" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="bg-white rounded-4 border p-1">
        <form asp-action="UserManagement" method="get" class="p-3">
            <input type="hidden" name="filter" value="@selectedFilter" />
            <div class="search-wrapper shadow-sm">
                <i class="bi bi-search text-muted"></i>
                <input type="text" name="search" placeholder="Search users..." value="@Model.Search">
            </div>
        </form>

        <table class="table align-middle mb-0">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="ps-4" style="font-size: 0.85rem; font-weight: 500;">User</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">System Role</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">Employee Role</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">Joined</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">Status</th>
                    <th style="font-size: 0.85rem; font-weight: 500;" class="text-end pe-4"></th>
                </tr>
            </thead>
            <tbody id="umUsersTableBody">
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td class="ps-4 py-4 text-muted" colspan="6">No users found.</td>
                    </tr>
                }
                @foreach (var user in Model.Users)
                {
                    var initials = string.Concat((user.FullName ?? user.Email ?? "U").Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
                    var employeeRole = (user.Email != null && Model.EmployeeRolesByEmail.TryGetValue(user.Email, out var role)) ? role : "N/A";
                    var displaySystemRole = string.Equals(user.Role, "superadmin", StringComparison.OrdinalIgnoreCase)
                        ? "Super Admin"
                        : string.IsNullOrWhiteSpace(user.Role)
                            ? "User"
                            : char.ToUpperInvariant(user.Role[0]) + user.Role.Substring(1);
                    var systemRoleClass = string.Equals(user.Role, "superadmin", StringComparison.OrdinalIgnoreCase)
                        ? "badge-system-superadmin"
                        : string.Equals(user.Role, "admin", StringComparison.OrdinalIgnoreCase)
                            ? "badge-system-admin"
                            : "badge-system-user";
                    var roleValue = (user.Role ?? string.Empty).ToLowerInvariant();
                    var isActiveEmployee = Model.ActiveEmployeeUserIds.Contains(user.Id);
                    var isInactiveUser = user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow;
                    var isActiveUser = !isInactiveUser;
                    <tr data-um-row="true"
                        data-system-role="@roleValue"
                        data-user-active="@(isActiveUser ? "true" : "false")"
                        data-is-active-employee="@(isActiveEmployee ? "true" : "false")">
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar-circle" style="width:36px; height:36px; background:#6366f1; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600;">@initials</div>
                                <div>
                                    <div class="fw-bold" style="font-size: 0.9rem;">@(string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName)</div>
                                    <div class="text-secondary" style="font-size: 0.8rem;">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (string.Equals(user.Role, "superadmin", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="badge-role @systemRoleClass">Super Admin</span>
                            }
                            else
                            {
                                <select class="um-role-select badge-role @systemRoleClass"
                                        data-user-role-select="true"
                                        data-role="@roleValue"
                                        data-user-id="@user.Id"
                                        aria-label="Update user role">
                                    <option value="user" selected="@(roleValue == "user" ? "selected" : null)">User</option>
                                    <option value="admin" selected="@(roleValue == "admin" ? "selected" : null)">Admin</option>
                                </select>
                            }
                        </td>
                        <td><span class="badge-role badge-emp-role">@employeeRole</span></td>
                        <td class="text-secondary" style="font-size: 0.9rem;">@user.CreatedDate.ToString("MMM d, yyyy")</td>
                        <td>
                            <button type="button"
                                    class="um-status-switch @(isActiveUser ? "is-active" : "is-inactive")"
                                    data-user-status-toggle="true"
                                    data-user-id="@user.Id"
                                    data-active="@(isActiveUser ? "true" : "false")"
                                    role="switch"
                                    aria-checked="@(isActiveUser ? "true" : "false")"
                                    aria-label="Toggle user active status">
                                <span class="um-status-label um-status-label-on">Active</span>
                                <span class="um-status-label um-status-label-off">Inactive</span>
                                <span class="um-status-knob">
                                    <i class="bi @(isActiveUser ? "bi-check-lg" : "bi-x-lg")"></i>
                                </span>
                            </button>
                        </td>
                        <td class="text-end pe-4">
                            <div class="dropdown d-inline-block">
                                <button class="btn btn-sm ellipsis-action-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Actions" aria-label="Actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (canArchive)
                                    {
                                        <li>
                                            <form asp-action="DeleteUser" method="post" class="archive-confirm-form" data-archive-title="Archive User Account" data-archive-message="Archive this user account?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="dropdown-item text-warning"><i class="bi bi-archive me-2"></i>Archive</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="umNoFilterResultsRow" class="d-none">
                    <td class="ps-4 py-4 text-muted" colspan="6">No users found for this filter.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="inviteUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
        <div class="modal-content border-0 shadow-lg p-3" style="border-radius: 12px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">Invite User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="InviteUser" method="post" id="inviteUserForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label fw-semibold mb-2">Email Address</label>
                        <div class="input-group-custom">
                            <i class="bi bi-envelope"></i>
                            <input type="email" class="form-control" name="email" placeholder="user@company.com" required>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold mb-2">Role</label>
                        <select class="form-select custom-select" name="role">
                            <option value="user">User</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>

                    <p class="text-secondary mb-4" style="font-size: 0.85rem;">
                        The user account will be created only after the invitation is accepted.
                    </p>
                </form>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-end gap-2 pb-3">
                <button type="button" class="btn btn-outline-secondary px-4 py-2" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                <button type="submit" form="inviteUserForm" class="btn btn-save px-4 py-2">Send Invitation</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const filterCards = Array.from(document.querySelectorAll('[data-um-filter-card]'));
        const rows = Array.from(document.querySelectorAll('tr[data-um-row="true"]'));
        const emptyRow = document.getElementById('umNoFilterResultsRow');
        if (!filterCards.length || !rows.length) {
            return;
        }

        function matchesFilter(row, filter) {
            if (filter === 'admins') {
                const role = (row.getAttribute('data-system-role') || '').toLowerCase();
                return role === 'admin' || role === 'superadmin';
            }
            if (filter === 'employees') {
                return row.getAttribute('data-is-active-employee') === 'true';
            }
            return true;
        }

        function applyFilter(filter, updateUrl) {
            let visibleCount = 0;
            rows.forEach(function (row) {
                const visible = matchesFilter(row, filter);
                row.classList.toggle('d-none', !visible);
                if (visible) {
                    visibleCount += 1;
                }
            });

            if (emptyRow) {
                emptyRow.classList.toggle('d-none', visibleCount > 0);
            }

            filterCards.forEach(function (card) {
                card.classList.toggle('active', card.getAttribute('data-um-filter-card') === filter);
            });

            if (updateUrl) {
                const url = new URL(window.location.href);
                url.searchParams.set('filter', filter);
                window.history.pushState({ umFilter: filter }, '', url.toString());
            }
        }

        window.syncoraApplyUserManagementFilter = applyFilter;

        filterCards.forEach(function (card) {
            card.addEventListener('click', function (event) {
                event.preventDefault();
                const filter = card.getAttribute('data-um-filter-card') || 'all';
                applyFilter(filter, true);
            });
        });

        window.addEventListener('popstate', function () {
            const url = new URL(window.location.href);
            const filter = (url.searchParams.get('filter') || 'all').toLowerCase();
            applyFilter(filter, false);
        });

        applyFilter('@selectedFilter', false);
    })();

    (function () {
        const tokenInput = document.querySelector('#umStatusTokenForm input[name="__RequestVerificationToken"]');
        const statusSwitches = Array.from(document.querySelectorAll('[data-user-status-toggle="true"]'));
        const roleSelects = Array.from(document.querySelectorAll('[data-user-role-select="true"]'));
        const totalUsersCount = document.getElementById('umTotalUsersCount');
        const adminCount = document.getElementById('umAdminCount');
        const activeEmployeeCount = document.getElementById('umActiveEmployeeCount');

        if (!tokenInput) {
            return;
        }

        function showUmToast(message, isError) {
            const existing = document.getElementById('umActionToast');
            if (existing) {
                existing.remove();
            }

            const toast = document.createElement('div');
            toast.id = 'umActionToast';
            toast.className = isError ? 'syncora-toast syncora-toast-error' : 'syncora-toast';
            toast.innerHTML = '<i class="bi ' + (isError ? 'bi-exclamation-circle' : 'bi-check-circle') + '"></i>' + message;
            document.body.appendChild(toast);

            setTimeout(function () {
                toast.remove();
            }, 3200);
        }

        function setSwitchState(button, activeState) {
            button.dataset.active = activeState ? 'true' : 'false';
            button.setAttribute('aria-checked', activeState ? 'true' : 'false');
            button.classList.toggle('is-active', activeState);
            button.classList.toggle('is-inactive', !activeState);

            const icon = button.querySelector('.um-status-knob i');
            if (icon) {
                icon.className = activeState ? 'bi bi-check-lg' : 'bi bi-x-lg';
            }

            const row = button.closest('tr[data-um-row="true"]');
            if (row) {
                row.setAttribute('data-user-active', activeState ? 'true' : 'false');
            }
        }

        function setRoleSelectStyle(select, roleValue) {
            select.classList.remove('badge-system-user', 'badge-system-admin');
            select.classList.add(roleValue === 'admin' ? 'badge-system-admin' : 'badge-system-user');
        }

        roleSelects.forEach(function (select) {
            select.addEventListener('change', async function () {
                if (select.dataset.loading === 'true') {
                    return;
                }

                const userId = select.getAttribute('data-user-id');
                const previousRole = (select.dataset.role || select.value || 'user').toLowerCase();
                const nextRole = (select.value || 'user').toLowerCase();
                if (!userId) {
                    return;
                }

                select.dataset.loading = 'true';
                select.disabled = true;

                try {
                    const payload = new URLSearchParams();
                    payload.append('userId', userId);
                    payload.append('role', nextRole);

                    const response = await fetch('/UserManagement/UpdateRole', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'RequestVerificationToken': tokenInput.value
                        },
                        body: payload.toString()
                    });

                    const result = await response.json();
                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Unable to update role.');
                    }

                    select.dataset.role = result.role;
                    select.value = result.role;
                    setRoleSelectStyle(select, result.role);

                    const row = select.closest('tr[data-um-row="true"]');
                    if (row) {
                        row.setAttribute('data-system-role', result.role);
                    }

                    if (totalUsersCount) {
                        totalUsersCount.textContent = result.totalUsersCount;
                    }
                    if (adminCount) {
                        adminCount.textContent = result.adminCount;
                    }
                    if (activeEmployeeCount) {
                        activeEmployeeCount.textContent = result.activeEmployeeCount;
                    }

                    if (typeof window.syncoraApplyUserManagementFilter === 'function') {
                        const url = new URL(window.location.href);
                        const filter = (url.searchParams.get('filter') || 'all').toLowerCase();
                        window.syncoraApplyUserManagementFilter(filter, false);
                    }

                    showUmToast('User role updated.', false);
                } catch (error) {
                    select.value = previousRole;
                    setRoleSelectStyle(select, previousRole);
                    showUmToast(error && error.message ? error.message : 'Unable to update role.', true);
                } finally {
                    select.dataset.loading = 'false';
                    select.disabled = false;
                }
            });
        });

        statusSwitches.forEach(function (button) {
            button.addEventListener('click', async function () {
                if (button.dataset.loading === 'true') {
                    return;
                }

                const userId = button.getAttribute('data-user-id');
                const currentState = button.dataset.active === 'true';
                const nextState = !currentState;
                if (!userId) {
                    return;
                }

                button.dataset.loading = 'true';
                button.classList.add('is-loading');

                try {
                    const payload = new URLSearchParams();
                    payload.append('userId', userId);
                    payload.append('isActive', String(nextState));

                    const response = await fetch('/UserManagement/ToggleStatus', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'RequestVerificationToken': tokenInput.value
                        },
                        body: payload.toString()
                    });

                    const result = await response.json();
                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Unable to update user status.');
                    }

                    setSwitchState(button, !!result.isActive);

                    const row = button.closest('tr[data-um-row="true"]');
                    if (row && result.hasEmployeeRecord) {
                        row.setAttribute('data-is-active-employee', result.isActive ? 'true' : 'false');
                    }

                    if (totalUsersCount) {
                        totalUsersCount.textContent = result.totalUsersCount;
                    }
                    if (adminCount) {
                        adminCount.textContent = result.adminCount;
                    }
                    if (activeEmployeeCount) {
                        activeEmployeeCount.textContent = result.activeEmployeeCount;
                    }

                    if (typeof window.syncoraApplyUserManagementFilter === 'function') {
                        const url = new URL(window.location.href);
                        const filter = (url.searchParams.get('filter') || 'all').toLowerCase();
                        window.syncoraApplyUserManagementFilter(filter, false);
                    }
                    showUmToast(result.isActive ? 'User activated.' : 'User deactivated.', false);
                } catch (error) {
                    showUmToast(error && error.message ? error.message : 'Unable to update user status.', true);
                } finally {
                    button.dataset.loading = 'false';
                    button.classList.remove('is-loading');
                }
            });
        });
    })();
</script>


