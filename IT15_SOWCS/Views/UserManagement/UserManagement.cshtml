@model IT15_SOWCS.ViewModels.UserManagementPageViewModel
@{
    Layout = "_UserManagementLayout";
    ViewData["Title"] = "User Management";
    var selectedFilter = (Model.SelectedFilter ?? "all").ToLowerInvariant();
    var searchQuery = string.IsNullOrWhiteSpace(Model.Search) ? null : Model.Search;
}

<div class="um-container">
    <div class="um-header">
        <div class="um-title">
            <h2>User Management</h2>
            <p>Manage system users and access</p>
        </div>
        <button class="btn-invite" data-bs-toggle="modal" data-bs-target="#inviteUserModal">
            <i class="bi bi-person-plus"></i> Invite User
        </button>
    </div>

    @if (TempData["UserManagementError"] is string userManagementError)
    {
        <div class="alert alert-danger">@userManagementError</div>
    }

    <div class="um-stats-grid">
        <a class="stat-card stat-filter-card @(selectedFilter == "all" ? "active" : string.Empty)"
           data-um-filter-card="all"
           asp-action="UserManagement"
           asp-route-filter="all"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-blue">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.TotalUsersCount</span>
                <span class="stat-label">Total Users</span>
            </div>
        </a>
        <a class="stat-card stat-filter-card @(selectedFilter == "admins" ? "active" : string.Empty)"
           data-um-filter-card="admins"
           asp-action="UserManagement"
           asp-route-filter="admins"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-purple">
                <i class="bi bi-shield-lock"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.AdminCount</span>
                <span class="stat-label">Admins</span>
            </div>
        </a>
        <a class="stat-card stat-filter-card @(selectedFilter == "employees" ? "active" : string.Empty)"
           data-um-filter-card="employees"
           asp-action="UserManagement"
           asp-route-filter="employees"
           asp-route-search="@searchQuery">
            <div class="stat-icon icon-green">
                <i class="bi bi-person-check"></i>
            </div>
            <div class="stat-info">
                <span class="stat-value">@Model.ActiveEmployeeCount</span>
                <span class="stat-label">Active Employees</span>
            </div>
        </a>
    </div>

    <div class="bg-white rounded-4 border p-1">
        <form asp-action="UserManagement" method="get" class="p-3">
            <input type="hidden" name="filter" value="@selectedFilter" />
            <div class="search-wrapper shadow-sm">
                <i class="bi bi-search text-muted"></i>
                <input type="text" name="search" placeholder="Search users..." value="@Model.Search">
            </div>
        </form>

        <table class="table align-middle mb-0">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="ps-4" style="font-size: 0.85rem; font-weight: 500;">User</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">System Role</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">Employee Role</th>
                    <th style="font-size: 0.85rem; font-weight: 500;">Joined</th>
                    <th style="font-size: 0.85rem; font-weight: 500;" class="text-end pe-4"></th>
                </tr>
            </thead>
            <tbody id="umUsersTableBody">
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td class="ps-4 py-4 text-muted" colspan="5">No users found.</td>
                    </tr>
                }
                @foreach (var user in Model.Users)
                {
                    var initials = string.Concat((user.FullName ?? user.Email ?? "U").Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
                    var employeeRole = (user.Email != null && Model.EmployeeRolesByEmail.TryGetValue(user.Email, out var role)) ? role : "N/A";
                    var displaySystemRole = string.Equals(user.Role, "superadmin", StringComparison.OrdinalIgnoreCase)
                        ? "Super Admin"
                        : string.IsNullOrWhiteSpace(user.Role)
                            ? "User"
                            : char.ToUpperInvariant(user.Role[0]) + user.Role.Substring(1);
                    var systemRoleClass = string.Equals(user.Role, "superadmin", StringComparison.OrdinalIgnoreCase)
                        ? "badge-system-superadmin"
                        : string.Equals(user.Role, "admin", StringComparison.OrdinalIgnoreCase)
                            ? "badge-system-admin"
                            : "badge-system-user";
                    var roleValue = (user.Role ?? string.Empty).ToLowerInvariant();
                    var isActiveEmployee = Model.ActiveEmployeeUserIds.Contains(user.Id);
                    <tr data-um-row="true"
                        data-system-role="@roleValue"
                        data-is-active-employee="@(isActiveEmployee ? "true" : "false")">
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar-circle" style="width:36px; height:36px; background:#6366f1; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:600;">@initials</div>
                                <div>
                                    <div class="fw-bold" style="font-size: 0.9rem;">@(string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName)</div>
                                    <div class="text-secondary" style="font-size: 0.8rem;">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge-role @systemRoleClass">@displaySystemRole</span>
                        </td>
                        <td><span class="badge-role badge-emp-role">@employeeRole</span></td>
                        <td class="text-secondary" style="font-size: 0.9rem;">@user.CreatedDate.ToString("MMM d, yyyy")</td>
                        <td class="text-end pe-4">
                            <div class="dropdown d-inline-block">
                                <button class="btn btn-sm ellipsis-action-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Actions" aria-label="Actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-action="DeleteUser" method="post" class="archive-confirm-form" data-archive-title="Archive User Account" data-archive-message="Archive this user account?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="dropdown-item text-warning"><i class="bi bi-archive me-2"></i>Archive</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="umNoFilterResultsRow" class="d-none">
                    <td class="ps-4 py-4 text-muted" colspan="5">No users found for this filter.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="inviteUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
        <div class="modal-content border-0 shadow-lg p-3" style="border-radius: 12px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">Invite User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="InviteUser" method="post" id="inviteUserForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label fw-semibold mb-2">Email Address</label>
                        <div class="input-group-custom">
                            <i class="bi bi-envelope"></i>
                            <input type="email" class="form-control" name="email" placeholder="user@company.com" required>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold mb-2">Role</label>
                        <select class="form-select custom-select" name="role">
                            <option value="user">User</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>

                    <p class="text-secondary mb-4" style="font-size: 0.85rem;">
                        The user is created with a temporary password: <strong>TempPass123!</strong>.
                    </p>
                </form>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-end gap-2 pb-3">
                <button type="button" class="btn btn-outline-secondary px-4 py-2" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                <button type="submit" form="inviteUserForm" class="btn btn-save px-4 py-2">Send Invitation</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const filterCards = Array.from(document.querySelectorAll('[data-um-filter-card]'));
        const rows = Array.from(document.querySelectorAll('tr[data-um-row="true"]'));
        const emptyRow = document.getElementById('umNoFilterResultsRow');
        if (!filterCards.length || !rows.length) {
            return;
        }

        function matchesFilter(row, filter) {
            if (filter === 'admins') {
                const role = (row.getAttribute('data-system-role') || '').toLowerCase();
                return role === 'admin' || role === 'superadmin';
            }
            if (filter === 'employees') {
                return row.getAttribute('data-is-active-employee') === 'true';
            }
            return true;
        }

        function applyFilter(filter, updateUrl) {
            let visibleCount = 0;
            rows.forEach(function (row) {
                const visible = matchesFilter(row, filter);
                row.classList.toggle('d-none', !visible);
                if (visible) {
                    visibleCount += 1;
                }
            });

            if (emptyRow) {
                emptyRow.classList.toggle('d-none', visibleCount > 0);
            }

            filterCards.forEach(function (card) {
                card.classList.toggle('active', card.getAttribute('data-um-filter-card') === filter);
            });

            if (updateUrl) {
                const url = new URL(window.location.href);
                url.searchParams.set('filter', filter);
                window.history.pushState({ umFilter: filter }, '', url.toString());
            }
        }

        filterCards.forEach(function (card) {
            card.addEventListener('click', function (event) {
                event.preventDefault();
                const filter = card.getAttribute('data-um-filter-card') || 'all';
                applyFilter(filter, true);
            });
        });

        window.addEventListener('popstate', function () {
            const url = new URL(window.location.href);
            const filter = (url.searchParams.get('filter') || 'all').toLowerCase();
            applyFilter(filter, false);
        });

        applyFilter('@selectedFilter', false);
    })();
</script>


