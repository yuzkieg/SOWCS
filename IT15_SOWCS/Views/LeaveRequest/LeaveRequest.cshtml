@model IT15_SOWCS.ViewModels.LeaveRequestsPageViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IT15_SOWCS.Models.Users> UserManager
@{
    Layout = "_LeaveRequestLayout";
    ViewData["Title"] = "Leave Requests";
    var currentUser = await UserManager.GetUserAsync(User);
    var canArchive = string.Equals(currentUser?.Role, "superadmin", StringComparison.OrdinalIgnoreCase);
}

<div class="leave-container">
    <div class="leave-header-section">
        <div class="leave-title">
            <h2>Leave Requests</h2>
            <p>Submit and track your leave requests</p>
        </div>
        <button class="btn-new-request" type="button" data-bs-toggle="modal" data-bs-target="#createLeaveRequestModal">
            <i class="bi bi-plus-lg"></i> New Request
        </button>
    </div>

    @if (TempData["LeaveError"] is string leaveError)
    {
        <div class="alert alert-danger">@leaveError</div>
    }

    <section class="leave-balance-grid">
        <article class="leave-balance-card annual">
            <div>
                <p>Annual Leave</p>
                <h4>@Model.AnnualLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </div>
            <i class="bi bi-calendar-event"></i>
        </article>
        <article class="leave-balance-card sick">
            <div>
                <p>Sick Leave</p>
                <h4>@Model.SickLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </div>
            <i class="bi bi-calendar-event"></i>
        </article>
        <article class="leave-balance-card personal">
            <div>
                <p>Personal Leave</p>
                <h4>@Model.PersonalLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </div>
            <i class="bi bi-calendar-event"></i>
        </article>
    </section>

    <form asp-action="LeaveRequest" method="get" class="leave-controls">
        <select class="form-select status-filter shadow-sm" name="status" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Status) || Model.Status == "All" ? "selected" : null)">All Requests</option>
            <option value="Approved" selected="@(Model.Status=="Approved" ? "selected" : null)">Approved</option>
            <option value="Rejected" selected="@(Model.Status=="Rejected" ? "selected" : null)">Rejected</option>
            <option value="Pending" selected="@(Model.Status=="Pending" ? "selected" : null)">Pending</option>
        </select>
    </form>

    @if (Model.Requests.Count == 0)
    {
        <div class="empty-state-section text-center py-5 bg-white rounded-4 border">
            <h5 class="mb-2">No leave requests yet</h5>
            <p class="text-muted mb-0">Create your first leave request.</p>
        </div>
    }
    else
    {
        @foreach (var request in Model.Requests)
        {
            var statusClass = request.status == "Approved" ? "approved" : request.status == "Rejected" ? "rejected" : "pending";
            var badgeClass = request.status == "Approved" ? "badge-approved" : request.status == "Rejected" ? "badge-rejected" : "badge-pending";
            <div class="leave-card">
                <div class="leave-info-group">
                    <div class="status-icon @statusClass">
                        <i class="bi @(request.status == "Rejected" ? "bi-x-circle" : request.status == "Approved" ? "bi-check-circle" : "bi-hourglass-split")"></i>
                    </div>
                    <div class="leave-details">
                        <div class="type-row">
                            <span class="leave-type">@request.leave_type</span>
                            <span class="badge-status @badgeClass">@request.status</span>
                        </div>
                        <div class="leave-date">@request.start_date.ToString("MMM d, yyyy") - @request.end_date.ToString("MMM d, yyyy")</div>
                        <div class="leave-note">Note: @request.reason</div>
                        @if (!string.IsNullOrWhiteSpace(request.review_notes))
                        {
                            <div class="leave-feedback">
                                Feedback: @request.review_notes
                            </div>
                        }
                    </div>
                </div>
                <div class="leave-meta">
                    @if (canArchive)
                    {
                        <div class="dropdown leave-card-actions">
                            <button class="btn btn-sm ellipsis-action-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Actions" aria-label="Actions">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-action="Delete" method="post" class="archive-confirm-form" data-archive-title="Archive Leave Request" data-archive-message="Archive this leave request?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="leaveRequestId" value="@request.LR_id" />
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-archive me-2"></i>Archive
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    <div class="day-count-wrap">
                        <div class="day-count">@request.days_count</div>
                        <span class="day-label">days</span>
                        <div class="submitted-date">Submitted @request.start_date.ToString("MMM d")</div>
                    </div>
                </div>
            </div>
        }
    }

    <div class="modal fade" id="createLeaveRequestModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Submit Leave Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-3">
                    <form asp-action="Create" method="post" id="leaveForm">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Leave Type</label>
                            <select class="form-select custom-input" name="leaveType" required>
                                <option>Annual Leave</option>
                                <option>Sick Leave</option>
                                <option>Unpaid Leave</option>
                                <option>Personal Leave</option>
                            </select>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold">Start Date</label>
                                <input type="date"
                                       class="form-control custom-input"
                                       id="leaveStartDate"
                                       name="startDate"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       required>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold">End Date</label>
                                <input type="date"
                                       class="form-control custom-input"
                                       id="leaveEndDate"
                                       name="endDate"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Reason (Optional)</label>
                            <textarea class="form-control custom-input"
                                      rows="4"
                                      name="reason"
                                      placeholder="Brief description of your leave reason"></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-save px-4">Submit Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const startDateInput = document.getElementById('leaveStartDate');
    const endDateInput = document.getElementById('leaveEndDate');
    const createLeaveRequestModal = document.getElementById('createLeaveRequestModal');

    function syncEndDateMin() {
        if (!startDateInput || !endDateInput) return;
        const today = '@DateTime.Today.ToString("yyyy-MM-dd")';
        const minDate = startDateInput.value && startDateInput.value > today ? startDateInput.value : today;
        endDateInput.min = minDate;
        if (endDateInput.value && endDateInput.value < minDate) {
            endDateInput.value = minDate;
        }
    }

    startDateInput?.addEventListener('change', syncEndDateMin);
    createLeaveRequestModal?.addEventListener('shown.bs.modal', syncEndDateMin);
    syncEndDateMin();
</script>



