@{
    Layout = "_LeaveRequestLayout";
    ViewData["Title"] = "Leave Requests";
}

<div class="leave-container">
    <div class="leave-header-section">
        <div class="leave-title">
            <h2>Leave Requests</h2>
            <p>Submit and track your leave requests</p>
        </div>
        <button class="btn-new-request">
            <i class="bi bi-plus-lg"></i> New Request
        </button>
    </div>

    <div class="leave-controls">
        <select class="filter-dropdown">
            <option>All Requests</option>
            <option>Approved</option>
            <option>Rejected</option>
            <option>Pending</option>
        </select>
    </div>

    <div class="leave-card">
        <div class="leave-info-group">
            <div class="status-icon approved">
                <i class="bi bi-check-circle"></i>
            </div>
            <div class="leave-details">
                <div class="type-row">
                    <span class="leave-type">Sick Leave</span>
                    <span class="badge-status badge-approved">Approved</span>
                </div>
                <div class="leave-date">Jan 8, 2026 — Jan 13, 2026</div>
                <div class="leave-note">Note: Pak u</div>
            </div>
        </div>
        <div class="leave-meta">
            <div class="day-count">6</div>
            <span class="day-label">days</span>
            <div class="submitted-date">Submitted Jan 21</div>
        </div>
    </div>

    <div class="leave-card">
        <div class="leave-info-group">
            <div class="status-icon rejected">
                <i class="bi bi-x-circle"></i>
            </div>
            <div class="leave-details">
                <div class="type-row">
                    <span class="leave-type">Sick Leave</span>
                    <span class="badge-status badge-rejected">Rejected</span>
                </div>
                <div class="leave-date">Jan 8, 2026 — Jan 12, 2026</div>
                <div class="leave-note">hehe<br />Note: paku</div>
            </div>
        </div>
        <div class="leave-meta">
            <div class="day-count">5</div>
            <span class="day-label">days</span>
            <div class="submitted-date">Submitted Jan 21</div>
        </div>
    </div>
    <div id="leaveModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Submit Leave Request</h3>
                <button class="close-modal" id="closeModal">&times;</button>
            </div>

            <form id="leaveForm">
                <div class="form-group">
                    <label>Leave Type</label>
                    <select class="form-control">
                        <option>Annual Leave (0 days left)</option>
                        <option>Sick Leave</option>
                        <option>Unpaid Leave</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="date" class="form-control">
                    </div>
                </div>

                <div class="form-group">
                    <label>Reason (Optional)</label>
                    <textarea class="form-control" rows="4" placeholder="Brief description of your leave reason"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-cancel" id="cancelBtn">Cancel</button>
                    <button type="submit" class="btn-submit">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById('leaveModal');
    const openBtn = document.querySelector('.btn-new-request');
    const closeBtn = document.getElementById('closeModal');
    const cancelBtn = document.getElementById('cancelBtn');

    openBtn.addEventListener('click', () => {
        modal.style.display = 'flex';
    });

    const closeModal = () => {
        modal.style.display = 'none';
    };

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);

    window.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });
</script>