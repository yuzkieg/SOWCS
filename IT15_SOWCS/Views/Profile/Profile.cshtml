@model IT15_SOWCS.ViewModels.ProfilePageViewModel
@using System.Linq
@{
    Layout = "_ProfileLayout";
    ViewData["Title"] = "Profile Settings";
    var employee = Model.Employee;
    var fullName = !string.IsNullOrWhiteSpace(employee?.full_name)
        ? employee.full_name
        : (string.IsNullOrWhiteSpace(Model.User.FullName) ? (Model.User.Email ?? "User") : Model.User.FullName);
    var employeeRole = string.IsNullOrWhiteSpace(employee?.employee_role) ? "Team Member" : employee!.employee_role;
    var employeeDepartment = string.IsNullOrWhiteSpace(employee?.department) ? "Not Assigned" : employee!.department;
    var phoneNumber = string.IsNullOrWhiteSpace(employee?.contact_number) ? "Not Provided" : employee!.contact_number;
    var initials = string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
}

<div class="profile-container">
    <div class="card profile-header-card border-0 shadow-sm mb-4">
        <div class="profile-banner"></div>
        <div class="card-body profile-info-section">
            <div class="profile-avatar-wrapper">
                <div class="profile-main-avatar">@initials</div>
            </div>
            <div class="profile-text-details">
                <h4 class="fw-bold mb-0 text-uppercase">@fullName</h4>
                <div class="d-flex gap-2 profile-role-badges">
                    <span class="badge badge-employee">@employeeRole</span>
                    <span class="badge badge-dept">@employeeDepartment</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card contact-info-card border-0 shadow-sm">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4">Contact Information</h5>

            <div class="row g-4">
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Full Name</label>
                    <div class="input-group-custom">
                        <i class="bi bi-person"></i>
                        <input type="text" class="form-control-plaintext" value="@fullName" readonly>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Email Address</label>
                    <div class="input-group-custom">
                        <input type="email" class="form-control-plaintext" value="@Model.User.Email" readonly>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Phone Number</label>
                    <div class="input-group-custom">
                        <i class="bi bi-telephone"></i>
                        <input type="text" class="form-control-plaintext" value="@phoneNumber" readonly>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold">Department</label>
                    <div class="input-group-custom">
                        <i class="bi bi-building"></i>
                        <input type="text" class="form-control-plaintext" value="@employeeDepartment" readonly>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="password-settings-block">
                <h5 class="fw-bold mb-1">Password Settings</h5>
                <p class="text-muted mb-3">Request a verified password change and set a new password securely.</p>

                @if (!Model.HasPassword)
                {
                    <form asp-action="SetInitialPassword" method="post" class="row g-3 align-items-end">
                        @Html.AntiForgeryToken()
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">New Password</label>
                            <input type="password" name="newPassword" class="form-control profile-input" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Confirm Password</label>
                            <input type="password" name="confirmPassword" class="form-control profile-input" required />
                        </div>
                        <div class="col-md-2 d-grid">
                            <button type="submit" class="btn btn-save-password">Save</button>
                        </div>
                    </form>
                }
                else
                {
                    <button type="button" class="btn btn-save-password" data-bs-toggle="modal" data-bs-target="#verifyPasswordModal">
                        Change Password
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="verifyPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content profile-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Verify Password Change</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="mb-3 fs-6">
                    Send a verification email to <strong>@Model.User.Email</strong> before changing your password?
                </p>
                <p class="text-muted mb-4">
                    Open the email and click the verify button. This page will detect it automatically and open the Set New Password modal.
                </p>
                <form id="verifyPasswordEmailForm" asp-action="SendPasswordVerificationEmail" method="post" class="d-flex justify-content-end gap-2">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="sendVerifyEmailBtn" class="btn btn-save px-4">Send Verification Email</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="setPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content profile-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Set New Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="ResetPasswordFromProfile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="token" value="@Model.ResetToken" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">New Password</label>
                        <input type="password" name="newPassword" class="form-control profile-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Confirm Password</label>
                        <input type="password" name="confirmPassword" class="form-control profile-input" required />
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const shouldOpenSetPasswordModal = '@(Model.OpenSetPasswordModal ? "true" : "false")' === 'true';
            const modalElement = document.getElementById('setPasswordModal');
            let modalInstance = null;
            let verificationHandled = false;
            let isSubmittingNewPassword = false;

            function openSetPasswordModal() {
                if (!modalElement) {
                    return;
                }
                modalInstance = modalInstance || new bootstrap.Modal(modalElement);
                modalInstance.show();
            }

            async function clearVerifiedState() {
                try {
                    await fetch('@Url.Action("ClearPasswordVerificationState", "Profile")', {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                } catch {
                }
            }

            if (shouldOpenSetPasswordModal) {
                openSetPasswordModal();
            }

            async function checkVerificationStatus() {
                try {
                    const response = await fetch('@Url.Action("PasswordVerificationStatus", "Profile")', {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!response.ok) return;

                    const payload = await response.json();
                    if (!payload || !payload.verified || !payload.token) return;

                    const tokenInput = document.querySelector('#setPasswordModal input[name="token"]');
                    if (tokenInput) {
                        tokenInput.value = payload.token;
                    }

                    openSetPasswordModal();
                    verificationHandled = true;
                } catch {
                }
            }

            setInterval(function () {
                if (verificationHandled) {
                    return;
                }
                checkVerificationStatus();
            }, 4000);

            const verifyForm = document.getElementById('verifyPasswordEmailForm');
            const sendVerifyEmailBtn = document.getElementById('sendVerifyEmailBtn');
            verifyForm?.addEventListener('submit', function () {
                if (!sendVerifyEmailBtn) return;
                sendVerifyEmailBtn.disabled = true;
                sendVerifyEmailBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Sending...';
            });

            const resetPasswordForm = document.querySelector('#setPasswordModal form');
            resetPasswordForm?.addEventListener('submit', function () {
                isSubmittingNewPassword = true;
            });

            modalElement?.addEventListener('hidden.bs.modal', function () {
                if (isSubmittingNewPassword) {
                    return;
                }

                if (!verificationHandled) {
                    return;
                }

                verificationHandled = false;
                clearVerifiedState();
            });
        });
    </script>
}
