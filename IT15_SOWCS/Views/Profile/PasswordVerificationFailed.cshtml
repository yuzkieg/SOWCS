@{
    ViewData["Title"] = "Verification Failed";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box text-center">
        <h2 class="mb-3">Verification link is invalid or expired</h2>
        <p class="text-muted mb-4">Please request a new password verification email from Profile Settings.</p>
        <a class="btn btn-primary w-100" href="@Url.Action("Profile", "Profile")">Back to website</a>
    </div>
</div>
