@model IT15_SOWCS.ViewModels.ApprovalsPageViewModel
@{
    Layout = "_ApprovalsLayout";
    ViewData["Title"] = "Approvals";
}

<div class="approvals-container">
    <div class="approvals-header">
        <h2>Approvals</h2>
        <p>Review and approve pending requests</p>
    </div>

    <div class="approvals-tabs">
        <button class="tab-btn active" id="btn-leave">
            <i class="bi bi-calendar-event"></i> Leave Requests <span class="badge-count">@Model.PendingLeaveRequests.Count</span>
        </button>
        <button class="tab-btn" id="btn-docs">
            <i class="bi bi-file-earmark-text"></i> Documents <span class="badge-count">@Model.PendingDocuments.Count</span>
        </button>
    </div>

    <div id="leave-section">
        @if (Model.PendingLeaveRequests.Count == 0)
        {
            <div class="approval-card"><div class="text-muted">No pending leave requests.</div></div>
        }
        @foreach (var leave in Model.PendingLeaveRequests)
        {
            <div class="approval-card">
                <div class="approval-info">
                    <div class="type-icon icon-leave">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <div class="requester-name"><i class="bi bi-person"></i> @leave.employee_name</div>
                        <div class="request-title">@leave.leave_type</div>
                        <div class="request-meta">@leave.start_date.ToString("MMM d, yyyy") - @leave.end_date.ToString("MMM d, yyyy") (@leave.days_count days)</div>
                        <div class="request-comment">"@leave.reason"</div>
                    </div>
                </div>
                <div class="action-group">
                    <button class="btn-reject open-leave-action-modal"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#leaveActionModal"
                            data-id="@leave.LR_id"
                            data-status="Rejected"
                            data-employee="@leave.employee_name"
                            data-type="@leave.leave_type"
                            data-days="@leave.days_count">
                        <i class="bi bi-x-circle"></i> Reject
                    </button>
                    <button class="btn-approve open-leave-action-modal"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#leaveActionModal"
                            data-id="@leave.LR_id"
                            data-status="Approved"
                            data-employee="@leave.employee_name"
                            data-type="@leave.leave_type"
                            data-days="@leave.days_count">
                        <i class="bi bi-check-circle"></i> Approve
                    </button>
                </div>
            </div>
        }
    </div>

    <div id="doc-section" style="display: none;">
        @if (Model.PendingDocuments.Count == 0)
        {
            <div class="approval-card"><div class="text-muted">No pending documents.</div></div>
        }
        @foreach (var doc in Model.PendingDocuments)
        {
            <div class="approval-card">
                <div class="approval-info">
                    <div class="type-icon icon-doc">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>
                    <div>
                        <div class="requester-name"><i class="bi bi-person"></i> @doc.uploaded_by_email</div>
                        <div class="request-title">@doc.title</div>
                        <div class="request-meta">@doc.file_name • @doc.category</div>
                        <div class="request-comment">Uploaded @doc.uploaded_date.ToString("MMM d, yyyy")</div>
                    </div>
                </div>
                <div class="action-group">
                    <a class="btn-view" href="@doc.file_path" target="_blank">View</a>
                    <button class="btn-reject open-doc-action-modal"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#docActionModal"
                            data-id="@doc.document_id"
                            data-status="Rejected"
                            data-uploader="@(doc.uploaded_by_email ?? "Unknown")"
                            data-title="@doc.title"
                            data-category="@doc.category">
                        <i class="bi bi-x-circle"></i> Reject
                    </button>
                    <button class="btn-approve open-doc-action-modal"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#docActionModal"
                            data-id="@doc.document_id"
                            data-status="Approved"
                            data-uploader="@(doc.uploaded_by_email ?? "Unknown")"
                            data-title="@doc.title"
                            data-category="@doc.category">
                        <i class="bi bi-check-circle"></i> Approve
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="leaveActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content approval-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="leaveActionTitle">Leave Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="UpdateLeaveStatus" method="post" id="leaveActionForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="leaveActionId" />
                    <input type="hidden" name="status" id="leaveActionStatus" />

                    <div class="approval-summary-box">
                        <div class="summary-primary" id="leaveActionEmployee"></div>
                        <div class="summary-secondary" id="leaveActionType"></div>
                        <div class="summary-secondary" id="leaveActionDays"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Feedback</label>
                        <textarea class="form-control approval-feedback" name="notes" rows="4" placeholder="Add any feedback for the requester..."></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4" id="leaveActionSubmitBtn">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="docActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content approval-modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="docActionTitle">Document Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="UpdateDocumentStatus" method="post" id="docActionForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="docActionId" />
                    <input type="hidden" name="status" id="docActionStatus" />

                    <div class="approval-summary-box">
                        <div class="summary-primary" id="docActionUploader"></div>
                        <div class="summary-secondary" id="docActionDocTitle"></div>
                        <div class="summary-secondary" id="docActionCategory"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Feedback</label>
                        <textarea class="form-control approval-feedback" name="notes" rows="4" placeholder="Add any feedback for the requester..."></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4" id="docActionSubmitBtn">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#btn-leave').click(function () {
                $('.tab-btn').removeClass('active');
                $(this).addClass('active');
                $('#leave-section').show();
                $('#doc-section').hide();
            });

            $('#btn-docs').click(function () {
                $('.tab-btn').removeClass('active');
                $(this).addClass('active');
                $('#leave-section').hide();
                $('#doc-section').show();
            });

            $('.open-leave-action-modal').on('click', function () {
                const status = $(this).data('status');
                const actionText = status === 'Approved' ? 'Approve' : 'Reject';

                $('#leaveActionTitle').text(actionText + ' Leave Request');
                $('#leaveActionId').val($(this).data('id'));
                $('#leaveActionStatus').val(status);
                $('#leaveActionEmployee').text($(this).data('employee'));
                $('#leaveActionType').text($(this).data('type'));
                $('#leaveActionDays').text($(this).data('days') + ' days');
                $('#leaveActionSubmitBtn').text(actionText);
                $('#leaveActionSubmitBtn').toggleClass('btn-save', true);
                $('#leaveActionForm textarea[name="notes"]').val('');
            });

            $('.open-doc-action-modal').on('click', function () {
                const status = $(this).data('status');
                const actionText = status === 'Approved' ? 'Approve' : 'Reject';

                $('#docActionTitle').text(actionText + ' Document');
                $('#docActionId').val($(this).data('id'));
                $('#docActionStatus').val(status);
                $('#docActionUploader').text($(this).data('uploader'));
                $('#docActionDocTitle').text($(this).data('title'));
                $('#docActionCategory').text($(this).data('category'));
                $('#docActionSubmitBtn').text(actionText);
                $('#docActionSubmitBtn').toggleClass('btn-save', true);
                $('#docActionForm textarea[name="notes"]').val('');
            });
        });
    </script>
}
