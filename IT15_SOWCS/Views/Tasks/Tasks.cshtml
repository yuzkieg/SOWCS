@model IT15_SOWCS.ViewModels.TasksPageViewModel
@{
    ViewData["Title"] = "My Tasks";
    Layout = "_TasksLayout";
}

<div class="tasks-container">
    <div class="tasks-header d-flex justify-content-between align-items-start">
        <div class="tasks-title">
            <h2>My Tasks</h2>
            <p>Track and manage your assigned tasks</p>
        </div>
        <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createTaskModal">
            <i class="bi bi-plus-lg me-2"></i> New Task
        </button>
    </div>

    @if (TempData["TasksError"] is string tasksError)
    {
        <div class="alert alert-danger">@tasksError</div>
    }

    <form asp-action="Tasks" method="get" class="tasks-filters module-filters mb-4 d-flex gap-3">
        <div class="search-wrapper shadow-sm flex-grow-1">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="search" placeholder="Search tasks..." value="@Model.Search">
        </div>
        <select class="form-select status-filter shadow-sm" name="status" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Status) || Model.Status == "All" ? "selected" : null)">All Status</option>
            <option value="Pending" selected="@(Model.Status=="Pending" ? "selected" : null)">Pending</option>
            <option value="In Progress" selected="@(Model.Status=="In Progress" ? "selected" : null)">In Progress</option>
            <option value="Completed" selected="@(Model.Status=="Completed" ? "selected" : null)">Completed</option>
        </select>
        <select class="form-select status-filter shadow-sm" name="priority" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Priority) || Model.Priority == "All" ? "selected" : null)">All Priority</option>
            <option value="High" selected="@(Model.Priority=="High" ? "selected" : null)">High</option>
            <option value="Medium" selected="@(Model.Priority=="Medium" ? "selected" : null)">Medium</option>
            <option value="Low" selected="@(Model.Priority=="Low" ? "selected" : null)">Low</option>
        </select>
    </form>

    @if (Model.Tasks.Count == 0)
    {
        <div class="empty-state-wrapper d-flex flex-column align-items-center justify-content-center">
            <div class="icon-circle mb-3">
                <i class="bi bi-clipboard-check text-muted fs-2"></i>
            </div>
            <h4 class="fw-bold mb-1">No tasks found</h4>
            <p class="text-muted">Create and assign tasks to start tracking work.</p>
        </div>
    }
    else
    {
        <div class="table-responsive bg-white border rounded-4 p-2">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Project</th>
                        <th>Assigned To</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Due</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@task.title</div>
                                <div class="text-muted small">@task.description</div>
                            </td>
                            <td>@(task.Project?.name ?? task.project_name)</td>
                            <td>@task.assigned_name</td>
                            <td>@task.status</td>
                            <td>@task.priority</td>
                            <td>@task.due_date.ToString("MMM d, yyyy")</td>
                            <td class="text-end">
                                <details class="d-inline-block text-start">
                                    <summary class="btn btn-sm btn-outline-secondary">Edit</summary>
                                    <form asp-action="Update" method="post" class="border rounded-3 p-3 bg-light mt-2" style="min-width: 320px;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <div class="mb-2">
                                            <label class="form-label small">Title</label>
                                            <input class="form-control form-control-sm" name="title" value="@task.title" required />
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small">Description</label>
                                            <textarea class="form-control form-control-sm" name="description" rows="2">@task.description</textarea>
                                        </div>
                                        <div class="row g-2 mb-2">
                                            <div class="col-4">
                                                <label class="form-label small">Status</label>
                                                <select class="form-select form-select-sm" name="status">
                                                    <option selected="@(task.status=="Pending" ? "selected" : null)">Pending</option>
                                                    <option selected="@(task.status=="In Progress" ? "selected" : null)">In Progress</option>
                                                    <option selected="@(task.status=="Completed" ? "selected" : null)">Completed</option>
                                                </select>
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label small">Priority</label>
                                                <select class="form-select form-select-sm" name="priority">
                                                    <option selected="@(task.priority=="Low" ? "selected" : null)">Low</option>
                                                    <option selected="@(task.priority=="Medium" ? "selected" : null)">Medium</option>
                                                    <option selected="@(task.priority=="High" ? "selected" : null)">High</option>
                                                </select>
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label small">Due Date</label>
                                                <input type="date" class="form-control form-control-sm" name="dueDate" value="@task.due_date.ToString("yyyy-MM-dd")" />
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                        </div>
                                    </form>
                                </details>
                                <form asp-action="Delete" method="post" class="d-inline-block ms-1" onsubmit="return confirm('Archive this task?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="taskId" value="@task.task_id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Archive</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Task Title</label>
                        <input name="title" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Description</label>
                        <textarea name="description" class="form-control custom-input" rows="2"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Project</label>
                            <select name="projectId" class="form-select custom-input" required>
                                @foreach (var project in Model.Projects)
                                {
                                    <option value="@project.project_id">@project.name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Assign To</label>
                            <select name="employeeId" class="form-select custom-input" required>
                                @foreach (var employee in Model.Employees)
                                {
                                    <option value="@employee.employee_id">@employee.full_name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-4">
                            <label class="form-label small fw-bold text-muted">Status</label>
                            <select name="status" class="form-select custom-input">
                                <option>Pending</option>
                                <option>In Progress</option>
                                <option>Completed</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-bold text-muted">Priority</label>
                            <select name="priority" class="form-select custom-input">
                                <option>Low</option>
                                <option selected>Medium</option>
                                <option>High</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label small fw-bold text-muted">Due Date</label>
                            <input type="date" name="dueDate" class="form-control custom-input" required />
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Create Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

