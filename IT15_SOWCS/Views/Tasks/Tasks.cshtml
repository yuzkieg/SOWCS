@model IT15_SOWCS.ViewModels.TasksPageViewModel
@{
    ViewData["Title"] = "My Tasks";
    Layout = "_TasksLayout";

    var todoTasks = Model.Tasks.Where(task => task.status == "Pending").ToList();
    var inProgressTasks = Model.Tasks.Where(task => task.status == "In Progress").ToList();
    var reviewTasks = Model.Tasks.Where(task => task.status == "Review").ToList();
    var completedTasks = Model.Tasks.Where(task => task.status == "Completed").ToList();
}

<div class="tasks-container">
    <div class="tasks-header">
        <div class="tasks-title">
            <h2>My Tasks</h2>
            <p>Track and manage your assigned tasks</p>
        </div>
    </div>

    @if (TempData["TasksError"] is string tasksError)
    {
        <div class="alert alert-danger">@tasksError</div>
    }

    <form asp-action="Tasks" method="get" class="tasks-filters module-filters">
        <div class="search-wrapper shadow-sm flex-grow-1">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="search" placeholder="Search tasks..." value="@Model.Search" />
        </div>
        <select class="form-select status-filter shadow-sm" name="status" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Status) || Model.Status == "All" ? "selected" : null)">All Status</option>
            <option value="Pending" selected="@(Model.Status=="Pending" ? "selected" : null)">To Do</option>
            <option value="In Progress" selected="@(Model.Status=="In Progress" ? "selected" : null)">In Progress</option>
            <option value="Review" selected="@(Model.Status=="Review" ? "selected" : null)">Review</option>
            <option value="Completed" selected="@(Model.Status=="Completed" ? "selected" : null)">Completed</option>
        </select>
        <select class="form-select status-filter shadow-sm" name="priority" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Priority) || Model.Priority == "All" ? "selected" : null)">All Priority</option>
            <option value="High" selected="@(Model.Priority=="High" ? "selected" : null)">High</option>
            <option value="Medium" selected="@(Model.Priority=="Medium" ? "selected" : null)">Medium</option>
            <option value="Low" selected="@(Model.Priority=="Low" ? "selected" : null)">Low</option>
        </select>
    </form>

    @if (Model.Tasks.Count == 0)
    {
        <div class="empty-state-wrapper d-flex flex-column align-items-center justify-content-center">
            <div class="icon-circle mb-3">
                <i class="bi bi-clipboard-check text-muted fs-2"></i>
            </div>
            <h4 class="fw-bold mb-1">No tasks found</h4>
            <p class="text-muted">Create and assign tasks to start tracking work.</p>
        </div>
    }
    else
    {
        <div class="tasks-board">
            <section class="task-column">
                <div class="lane-title">
                    <span class="lane-pill lane-todo">To Do</span>
                    <span>(@todoTasks.Count)</span>
                </div>
                @foreach (var task in todoTasks)
                {
                    <article class="task-card">
                        <div class="dropdown task-card-menu">
                            <button class="btn task-card-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Task actions">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="In Progress" />
                                        <button type="submit" class="dropdown-item">Move to In Progress</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Review" />
                                        <button type="submit" class="dropdown-item">Move to Review</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="dropdown-item">Mark Complete</button>
                                    </form>
                                </li>
                                <li>
                                    <button type="button"
                                            class="dropdown-item open-edit-task-modal"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editTaskModal"
                                            data-task-id="@task.task_id"
                                            data-title="@task.title"
                                            data-description="@task.description"
                                            data-employee-id="@task.employee_id"
                                            data-priority="@task.priority"
                                            data-due-date="@task.due_date.ToString("yyyy-MM-dd")"
                                            data-status="@task.status">Edit</button>
                                </li>
                                <li>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Archive this task?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <button type="submit" class="dropdown-item dropdown-item-danger">Archive</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <h6 class="task-card-title">@task.title</h6>
                        <p class="task-card-description">@task.description</p>
                        <div class="task-project-line">
                            <i class="bi bi-folder2"></i>
                            <span>@(task.Project?.name ?? task.project_name)</span>
                        </div>
                        <div class="task-card-footer">
                            <span class="priority-pill @(
                                task.priority == "High" ? "priority-high" :
                                task.priority == "Medium" ? "priority-medium" :
                                task.priority == "Urgent" ? "priority-critical" : "priority-low"
                            )">@task.priority</span>
                            <span class="task-date"><i class="bi bi-calendar-event"></i> @task.due_date.ToString("MMM d")</span>
                        </div>
                    </article>
                }
            </section>

            <section class="task-column">
                <div class="lane-title">
                    <span class="lane-pill lane-inprogress">In Progress</span>
                    <span>(@inProgressTasks.Count)</span>
                </div>
                @foreach (var task in inProgressTasks)
                {
                    <article class="task-card">
                        <div class="dropdown task-card-menu">
                            <button class="btn task-card-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Task actions">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Pending" />
                                        <button type="submit" class="dropdown-item">Move to To Do</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Review" />
                                        <button type="submit" class="dropdown-item">Move to Review</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="dropdown-item">Mark Complete</button>
                                    </form>
                                </li>
                                <li>
                                    <button type="button"
                                            class="dropdown-item open-edit-task-modal"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editTaskModal"
                                            data-task-id="@task.task_id"
                                            data-title="@task.title"
                                            data-description="@task.description"
                                            data-employee-id="@task.employee_id"
                                            data-priority="@task.priority"
                                            data-due-date="@task.due_date.ToString("yyyy-MM-dd")"
                                            data-status="@task.status">Edit</button>
                                </li>
                                <li>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Archive this task?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <button type="submit" class="dropdown-item dropdown-item-danger">Archive</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <h6 class="task-card-title">@task.title</h6>
                        <p class="task-card-description">@task.description</p>
                        <div class="task-project-line">
                            <i class="bi bi-folder2"></i>
                            <span>@(task.Project?.name ?? task.project_name)</span>
                        </div>
                        <div class="task-card-footer">
                            <span class="priority-pill @(
                                task.priority == "High" ? "priority-high" :
                                task.priority == "Medium" ? "priority-medium" :
                                task.priority == "Urgent" ? "priority-critical" : "priority-low"
                            )">@task.priority</span>
                            <span class="task-date"><i class="bi bi-calendar-event"></i> @task.due_date.ToString("MMM d")</span>
                        </div>
                    </article>
                }
            </section>

            <section class="task-column">
                <div class="lane-title">
                    <span class="lane-pill lane-review">Review</span>
                    <span>(@reviewTasks.Count)</span>
                </div>
                @foreach (var task in reviewTasks)
                {
                    <article class="task-card">
                        <div class="dropdown task-card-menu">
                            <button class="btn task-card-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Task actions">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Pending" />
                                        <button type="submit" class="dropdown-item">Move to To Do</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="In Progress" />
                                        <button type="submit" class="dropdown-item">Move to In Progress</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="dropdown-item">Mark Complete</button>
                                    </form>
                                </li>
                                <li>
                                    <button type="button"
                                            class="dropdown-item open-edit-task-modal"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editTaskModal"
                                            data-task-id="@task.task_id"
                                            data-title="@task.title"
                                            data-description="@task.description"
                                            data-employee-id="@task.employee_id"
                                            data-priority="@task.priority"
                                            data-due-date="@task.due_date.ToString("yyyy-MM-dd")"
                                            data-status="@task.status">Edit</button>
                                </li>
                                <li>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Archive this task?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <button type="submit" class="dropdown-item dropdown-item-danger">Archive</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <h6 class="task-card-title">@task.title</h6>
                        <p class="task-card-description">@task.description</p>
                        <div class="task-project-line">
                            <i class="bi bi-folder2"></i>
                            <span>@(task.Project?.name ?? task.project_name)</span>
                        </div>
                        <div class="task-card-footer">
                            <span class="priority-pill @(
                                task.priority == "High" ? "priority-high" :
                                task.priority == "Medium" ? "priority-medium" :
                                task.priority == "Urgent" ? "priority-critical" : "priority-low"
                            )">@task.priority</span>
                            <span class="task-date"><i class="bi bi-calendar-event"></i> @task.due_date.ToString("MMM d")</span>
                        </div>
                    </article>
                }
            </section>

            <section class="task-column">
                <div class="lane-title">
                    <span class="lane-pill lane-completed">Completed</span>
                    <span>(@completedTasks.Count)</span>
                </div>
                @foreach (var task in completedTasks)
                {
                    <article class="task-card">
                        <div class="dropdown task-card-menu">
                            <button class="btn task-card-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Task actions">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Pending" />
                                        <button type="submit" class="dropdown-item">Move to To Do</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="In Progress" />
                                        <button type="submit" class="dropdown-item">Move to In Progress</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="Move" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <input type="hidden" name="status" value="Review" />
                                        <button type="submit" class="dropdown-item">Move to Review</button>
                                    </form>
                                </li>
                                <li>
                                    <button type="button"
                                            class="dropdown-item open-edit-task-modal"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editTaskModal"
                                            data-task-id="@task.task_id"
                                            data-title="@task.title"
                                            data-description="@task.description"
                                            data-employee-id="@task.employee_id"
                                            data-priority="@task.priority"
                                            data-due-date="@task.due_date.ToString("yyyy-MM-dd")"
                                            data-status="@task.status">Edit</button>
                                </li>
                                <li>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Archive this task?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="taskId" value="@task.task_id" />
                                        <button type="submit" class="dropdown-item dropdown-item-danger">Archive</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <h6 class="task-card-title">@task.title</h6>
                        <p class="task-card-description">@task.description</p>
                        <div class="task-project-line">
                            <i class="bi bi-folder2"></i>
                            <span>@(task.Project?.name ?? task.project_name)</span>
                        </div>
                        <div class="task-card-footer">
                            <span class="priority-pill @(
                                task.priority == "High" ? "priority-high" :
                                task.priority == "Medium" ? "priority-medium" :
                                task.priority == "Urgent" ? "priority-critical" : "priority-low"
                            )">@task.priority</span>
                            <span class="task-date"><i class="bi bi-calendar-event"></i> @task.due_date.ToString("MMM d")</span>
                        </div>
                    </article>
                }
            </section>
        </div>
    }
</div>

<div class="modal fade" id="editTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Edit Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-action="Update" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" id="editTaskId" />
                    <input type="hidden" name="status" id="editTaskStatus" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task Title</label>
                        <input name="title" id="editTaskTitle" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" id="editTaskDescription" class="form-control custom-input" rows="3"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Assign To</label>
                            <select name="employeeId" id="editTaskEmployeeId" class="form-select custom-input" required>
                                @foreach (var employee in Model.Employees)
                                {
                                    <option value="@employee.employee_id">@employee.full_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Priority</label>
                            <select name="priority" id="editTaskPriority" class="form-select custom-input" required>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input type="date" name="dueDate" id="editTaskDueDate" class="form-control custom-input" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.open-edit-task-modal').forEach(function (button) {
        button.addEventListener('click', function () {
            document.getElementById('editTaskId').value = button.getAttribute('data-task-id') || '';
            document.getElementById('editTaskTitle').value = button.getAttribute('data-title') || '';
            document.getElementById('editTaskDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editTaskEmployeeId').value = button.getAttribute('data-employee-id') || '';
            document.getElementById('editTaskPriority').value = button.getAttribute('data-priority') || 'Medium';
            document.getElementById('editTaskDueDate').value = button.getAttribute('data-due-date') || '';
            document.getElementById('editTaskStatus').value = button.getAttribute('data-status') || 'Pending';
        });
    });
</script>
