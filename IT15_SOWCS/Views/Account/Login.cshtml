@using IT15_SOWCS.ViewModels;
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="account-container">
    <div class="account-box">
        <div class="logo-wrapper">
            <div class="logo-circle">
                <img src="~/images/SOWCS.png" alt="Syncora Logo" />
            </div>
        </div>

        <h2 class="text-center">Welcome to Syncora</h2>
        <p class="text-center text-muted-small mb-4">Sign in to continue</p>

        <form asp-controller="Account" asp-action="ExternalLogin" method="post">
            <input type="hidden" name="provider" value="Google" />
            <button type="submit" class="btn btn-google w-100 mb-4">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" />
                Continue with Google
            </button>
        </form>

        <div class="divider">
            <span>OR</span>
        </div>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            @if (ViewData["InactiveNotice"] is string inactiveNotice && !string.IsNullOrWhiteSpace(inactiveNotice))
            {
                <div class="alert alert-warning py-2">@inactiveNotice</div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text">
                        <i class="bi bi-envelope text-muted"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock text-muted"></i>
                    </span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Sign in</button>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="VerifyEmail" class="account-link text-muted-small">Forgot password?</a>
                <p class="text-muted-small mb-0">
                    Need an account?
                    <a asp-action="Register" class="account-link fw-bold">Sign up</a>
                </p>
            </div>
        </form>

        @{
            var inactiveEmail = (ViewData["InactiveEmail"]?.ToString() ?? TempData["InactiveEmail"]?.ToString() ?? string.Empty).Trim();
        }
        @if (!string.IsNullOrWhiteSpace(inactiveEmail))
        {
            <div class="mt-4 p-3 border rounded-3 bg-light">
                <h6 class="mb-2 fw-semibold">Account Inactive</h6>
                <p class="mb-3 text-muted-small">Your account is inactive. Send a reactivation request to the administrator.</p>
                <form asp-action="RequestReactivation" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@inactiveEmail" />
                    <div class="mb-2">
                        <input type="text" name="message" class="form-control" placeholder="Reason for reactivation request" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send Request</button>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}
