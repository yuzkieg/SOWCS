@model IT15_SOWCS.ViewModels.AuditLogsPageViewModel
@{
    Layout = "_AuditLogsLayout";
    ViewData["Title"] = "Audit Logs";
}

<div class="audit-container">
    <div class="audit-header d-flex justify-content-between align-items-start">
        <div>
            <h2>Audit Logs</h2>
            <p>Track all system activities and changes</p>
        </div>
    </div>

    <form asp-action="AuditLogs" method="get" class="audit-controls module-filters">
        <div class="search-wrapper shadow-sm">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="search" placeholder="Search logs..." value="@Model.Search">
        </div>
        <select class="form-select status-filter shadow-sm" name="action" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Action) || Model.Action == "All" ? "selected" : null)">All Actions</option>
            <option value="approved" selected="@(Model.Action=="approved" || Model.Action=="approve" ? "selected" : null)">Approve</option>
            <option value="rejected" selected="@(Model.Action=="rejected" || Model.Action=="reject" ? "selected" : null)">Reject</option>
            <option value="upload" selected="@(Model.Action=="upload" ? "selected" : null)">Upload</option>
            <option value="invite" selected="@(Model.Action=="invite" ? "selected" : null)">Invite</option>
            <option value="create" selected="@(Model.Action=="create" ? "selected" : null)">Create</option>
            <option value="update" selected="@(Model.Action=="update" ? "selected" : null)">Update</option>
            <option value="archive" selected="@(Model.Action=="archive" || Model.Action=="delete" ? "selected" : null)">Archive</option>
            <option value="restore" selected="@(Model.Action=="restore" ? "selected" : null)">Restore</option>
        </select>
    </form>

    <div class="audit-table-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Logs.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No logs found.</td></tr>
                }
                @foreach (var log in Model.Logs)
                {
                    var isNegative = log.action == "reject" || log.action == "rejected";
                    var badgeClass = isNegative ? "badge-reject" : "badge-approve";
                    <tr>
                        <td class="timestamp-text">@log.timestamp.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                        <td>
                            <div class="log-user-info">
                                <span class="log-user-name">@log.user_name</span>
                                <span class="log-user-email">@log.user_email</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge-action @badgeClass">
                                <i class="bi @(isNegative ? "bi-x-circle" : "bi-check-circle")"></i> @log.action
                            </span>
                        </td>
                        <td>@log.entity</td>
                        <td>@log.description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
