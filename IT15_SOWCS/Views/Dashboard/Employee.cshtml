@model IT15_SOWCS.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dashboard-page employee-dashboard-page">
    <section class="welcome-banner">
        <p class="welcome-label">Welcome back,</p>
        <h1 class="welcome-name">@Model.FullName</h1>
        <p class="welcome-subtitle">Stay on top of your tasks and projects.</p>
    </section>

    <section class="dashboard-stats">
        <article class="stat-card card-active-projects">
            <p class="stat-label">Active Projects</p>
            <h3 class="stat-value">@Model.ActiveProjectsCount</h3>
            <span class="stat-icon"><i class="bi bi-folder2"></i></span>
        </article>
        <article class="stat-card card-my-tasks">
            <p class="stat-label">My Tasks</p>
            <h3 class="stat-value">@Model.MyTasksCount</h3>
            <p class="stat-subtext">@Model.CompletedTasksCount completed</p>
            <span class="stat-icon"><i class="bi bi-clipboard-check"></i></span>
        </article>
        <article class="stat-card card-documents">
            <p class="stat-label">Documents</p>
            <h3 class="stat-value">@Model.DocumentsCount</h3>
            <span class="stat-icon"><i class="bi bi-file-earmark-text"></i></span>
        </article>
        <article class="stat-card card-pending-leaves">
            <p class="stat-label">Pending Leaves</p>
            <h3 class="stat-value">@Model.PendingLeavesCount</h3>
            <span class="stat-icon"><i class="bi bi-calendar-event"></i></span>
        </article>
    </section>

    <section class="dashboard-main-grid">
        <article class="panel-card">
            <header class="panel-header">
                <h5>My Tasks</h5>
                <a asp-controller="Tasks" asp-action="Tasks" class="panel-link">View All <i class="bi bi-arrow-right"></i></a>
            </header>

            <div class="overall-progress-wrap">
                <div class="overall-progress-label-row">
                    <span>Overall Progress</span>
                    <strong>@Model.OverallProgressPercent%</strong>
                </div>
                <div class="overall-progress-track">
                    <div class="overall-progress-fill" style="width:@Model.OverallProgressPercent%;"></div>
                </div>
            </div>

            @if (Model.MyTasks.Count == 0)
            {
                <div class="empty-dashboard-state">No tasks assigned yet.</div>
            }
            else
            {
                <div class="dashboard-task-list">
                    @foreach (var task in Model.MyTasks)
                    {
                        var statusLabel = task.Status == "Pending" ? "To Do" : task.Status;
                        var statusClass = task.Status == "Completed"
                            ? "badge-approved"
                            : task.Status == "In Progress"
                                ? "badge-inprogress"
                                : task.Status == "Review"
                                    ? "badge-review"
                                    : "badge-todo";
                        <div class="dashboard-task-item">
                            <div class="task-item-main">
                                <span class="task-dot"></span>
                                <div>
                                    <h6>@task.Title</h6>
                                    <p>@task.ProjectName</p>
                                </div>
                            </div>
                            <div class="task-item-right">
                                <span class="task-status-badge @statusClass">@statusLabel</span>
                                <span class="task-date">@task.DueDate.ToString("MMM d")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="panel-card">
            <header class="panel-header">
                <h5>Recent Activity</h5>
            </header>

            @if (Model.RecentActivities.Count == 0)
            {
                <div class="empty-dashboard-state">No recent activities found.</div>
            }
            else
            {
                <div class="activity-list">
                    @foreach (var item in Model.RecentActivities)
                    {
                        var iconClass = item.Type == "Document" ? "bi-file-earmark-text" : "bi-calendar-event";
                        var softClass = item.Type == "Document" ? "blue-soft-bg" : "orange-soft-bg";
                        var badgeClass = item.Status == "Approved" || item.Status == "Completed"
                            ? "badge-approved"
                            : item.Status == "Rejected"
                                ? "badge-rejected"
                                : "badge-pending";
                        <div class="activity-item">
                            <div class="activity-icon @softClass"><i class="bi @iconClass"></i></div>
                            <div class="activity-content">
                                <div>
                                    <h6>@item.Title</h6>
                                    <p>@item.Subtitle</p>
                                </div>
                                <div class="activity-meta">
                                    <span class="badge-status @badgeClass">@item.Status</span>
                                    <span class="date-text">@item.Date.ToString("MMM d")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>
    </section>

    <section class="employee-leave-balance-card panel-card">
        <header class="panel-header">
            <h5>Leave Balance</h5>
            <a asp-controller="LeaveRequest" asp-action="LeaveRequest" class="panel-link">Request Leave <i class="bi bi-arrow-right"></i></a>
        </header>
        <div class="employee-balance-grid">
            <article class="employee-balance-item annual">
                <p>Annual Leave</p>
                <h4>@Model.AnnualLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </article>
            <article class="employee-balance-item sick">
                <p>Sick Leave</p>
                <h4>@Model.SickLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </article>
            <article class="employee-balance-item personal">
                <p>Personal Leave</p>
                <h4>@Model.PersonalLeaveBalance.ToString("0")</h4>
                <span>days remaining</span>
            </article>
        </div>
    </section>
</div>
