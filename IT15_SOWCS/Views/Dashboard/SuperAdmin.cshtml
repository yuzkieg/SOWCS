@model IT15_SOWCS.ViewModels.SuperAdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="sa-page">
    <section class="sa-hero">
        <div class="sa-hero-left">
            <p class="sa-kicker"><i class="bi bi-stars"></i> Productivity Analytics - Super Admin</p>
            <h1>@Model.FullName.ToUpperInvariant()</h1>
            <p>Predictive talent intelligence dashboard - shifting from what happened to what it means for the future.</p>
        </div>
        <div class="sa-hero-right">
            <div><strong>@Model.TasksCompleted</strong><span>Tasks Completed</span></div>
            <div><strong>@Model.EmployeesCount</strong><span>Employees</span></div>
        </div>
    </section>

    <div class="sa-caption">Performance Metrics</div>
    <section class="sa-metrics">
        <article class="sa-metric-card">
            <p>Task Velocity</p>
            <h3>@Model.TaskVelocityDays <small>days</small></h3>
            <span>avg. assignment to completion</span>
        </article>
        <article class="sa-metric-card green">
            <p>Throughput</p>
            <h3>@Model.Throughput</h3>
            <span>@(Model.ThroughputDeltaPercent >= 0 ? "+" : "")@Model.ThroughputDeltaPercent% vs last month</span>
        </article>
        <article class="sa-metric-card purple">
            <p>Collab Score</p>
            <h3>@Model.CollaborationScore<small>/100</small></h3>
            <div class="sa-mini-progress"><div style="width:@Model.CollaborationScore%"></div></div>
        </article>
        <article class="sa-metric-card amber">
            <p>Completion Rate</p>
            <h3>@Model.CompletionRatePercent<small>%</small></h3>
            <span>@Model.CompletionNumerator of @Model.CompletionDenominator tasks</span>
        </article>
    </section>

    <section class="sa-panels">
        <article class="sa-panel risk">
            <header><h5><i class="bi bi-exclamation-triangle"></i> Reject Risk Model</h5><span>@Model.RejectRisks.Count flagged</span></header>
            @foreach (var item in Model.RejectRisks)
            {
                <div class="sa-person risk">
                    <div class="avatar">@item.Initials</div>
                    <div class="body">
                        <div class="name-line">@item.Name <span class="pill warn">@item.Classification</span></div>
                        <div class="meta">@item.RoleLabel</div>
                        <div class="stats"><span>@item.RejectRatePercent% reject rate</span><span>@item.CompletionPercent% completion</span><span>@(item.WoWPercent >= 0 ? "+" : "")@item.WoWPercent% WoW</span></div>
                    </div>
                </div>
            }
        </article>
        <article class="sa-panel top">
            <header><h5><i class="bi bi-stars"></i> Top Performer Model</h5><span>@Model.TopPerformers.Count identified</span></header>
            @foreach (var item in Model.TopPerformers)
            {
                <div class="sa-person top">
                    <div class="avatar">@item.Initials</div>
                    <div class="body">
                        <div class="name-line">@item.Name <span class="pill ok">@item.Classification</span></div>
                        <div class="meta">@item.RoleLabel</div>
                        <div class="stats"><span>@item.CompletionPercent% completion</span><span>@item.CollaborationScore collab</span><span>@item.Velocity velocity</span></div>
                    </div>
                </div>
            }
        </article>
    </section>

    <div class="sa-caption">Automated Next-Step Suggestions</div>
    <section class="sa-suggestion-grid">
        @foreach (var suggestion in Model.Suggestions)
        {
            var css = suggestion.Type == "positive" ? "positive" : "risk";
            <article class="sa-suggestion @css"
                     data-employee-id="@suggestion.EmployeeId"
                     data-employee-name="@suggestion.EmployeeName"
                     data-prediction-label="@suggestion.PredictionLabel">
                <p>@suggestion.Message</p>
                <div>
                    <button type="button"
                            class="sa-suggestion-action"
                            data-action="@(suggestion.Type == "positive" ? "nominate" : "review")">
                        @suggestion.ActionLabel
                    </button>
                    <button type="button" class="sa-suggestion-dismiss">Dismiss</button>
                </div>
            </article>
        }
    </section>

    <section class="sa-panel">
        <header><h5><i class="bi bi-people"></i> Full Employee Analytics Overview</h5></header>
        <div class="table-responsive">
            <table class="table sa-table mb-0">
                <thead>
                    <tr><th>Employee</th><th>Tasks</th><th>Completion</th><th>Reject %</th><th>WoW</th><th>Collab</th><th>Classification</th></tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.AnalyticsRows)
                    {
                        <tr>
                            <td><div class="sa-emp"><span>@row.Initials</span><div><strong>@row.Name</strong><small>@row.RoleLabel</small></div></div></td>
                            <td>@row.Tasks</td>
                            <td>@row.CompletionPercent%</td>
                            <td data-reject="@row.RejectPercent" data-classification="@row.Classification">@row.RejectPercent%</td>
                            <td>@(row.WoWPercent >= 0 ? "+" : "")@row.WoWPercent%</td>
                            <td><div class="sa-collab"><em style="width:@Math.Clamp(row.CollaborationScore, 0, 100)%"></em>@row.CollaborationScore</div></td>
                            <td><span class="pill @(row.Classification == "Reward Milestone" ? "ok" : row.Classification == "Stable" ? "stable" : "warn")">@row.Classification</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="sa-panel mt-4">
        <div id="predictionPanel">
            @await Html.PartialAsync("_SuperAdminPredictions", Model)
        </div>
    </section>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const panel = document.getElementById("predictionPanel");
        if (!panel) {
            return;
        }

        function attachPredictionHandler() {
            const select = document.getElementById("predictionPeriodSelect");
            if (!select) {
                return;
            }

            select.addEventListener("change", async function () {
                const period = select.value === "year" ? "year" : "month";
                const response = await fetch(`/Dashboard/SuperAdminPredictions?predictionPeriod=${period}`, {
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (!response.ok) {
                    return;
                }

                const html = await response.text();
                panel.innerHTML = html;
                attachPredictionHandler();
            });
        }

        attachPredictionHandler();

        function showToast(message) {
            const toast = document.createElement("div");
            toast.className = "syncora-toast";
            toast.innerHTML = '<i class="bi bi-info-circle"></i>' + message;
            document.body.appendChild(toast);
            setTimeout(function () { toast.remove(); }, 3000);
        }

        async function recordSuggestionAction(card, actionType) {
            const employeeId = card?.getAttribute("data-employee-id") || "";
            const employeeName = card?.getAttribute("data-employee-name") || "";
            const predictionLabel = card?.getAttribute("data-prediction-label") || "Stable";
            const periodSelect = document.getElementById("predictionPeriodSelect");
            const periodType = periodSelect?.value === "year" ? "year" : "month";

            const formData = new URLSearchParams();
            formData.append("employeeId", employeeId);
            formData.append("employeeName", employeeName);
            formData.append("predictionLabel", predictionLabel);
            formData.append("actionType", actionType);
            formData.append("periodType", periodType);

            try {
                const response = await fetch("/PredictionInsights/RecordAction", {
                    method: "POST",
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: formData.toString()
                });
                return response.ok;
            } catch {
                return false;
            }
        }

        document.querySelectorAll(".sa-suggestion-dismiss").forEach(function (btn) {
            btn.addEventListener("click", async function () {
                const card = btn.closest(".sa-suggestion");
                if (!card) {
                    return;
                }

                await recordSuggestionAction(card, "dismiss");
                card.remove();
            });
        });

        document.querySelectorAll(".sa-suggestion-action").forEach(function (btn) {
            btn.addEventListener("click", async function () {
                const card = btn.closest(".sa-suggestion");
                const action = btn.getAttribute("data-action");
                if (action === "review") {
                    const table = document.querySelector(".sa-table");
                    if (!table) {
                        showToast("Analytics table not available.");
                        return;
                    }

                    table.scrollIntoView({ behavior: "smooth", block: "start" });
                    table.querySelectorAll("td[data-reject]").forEach(function (cell) {
                        const reject = parseInt(cell.getAttribute("data-reject") || "0", 10);
                        const isRisk = reject >= 18;
                        cell.closest("tr")?.classList.toggle("table-warning", isRisk);
                    });
                    if (card) {
                        await recordSuggestionAction(card, "review_rejections");
                        card.remove();
                    }
                    showToast("Highlighted high reject-rate employees.");
                } else if (action === "nominate") {
                    if (card) {
                        await recordSuggestionAction(card, "nominate");
                        card.remove();
                    }
                    showToast("Nomination recorded.");
                }
            });
        });
    });
</script>
