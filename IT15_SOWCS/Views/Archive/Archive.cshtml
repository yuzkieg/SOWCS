@model IEnumerable<IT15_SOWCS.ViewModels.ArchiveItemModel>
@{
    ViewData["Title"] = "Archive";
    Layout = "_ArchiveLayout";
}

<div class="archive-container">
    <div class="archive-header">
        <h2>Archive</h2>
        <p>View and restore archived items</p>
    </div>

    @if (TempData["ArchiveError"] is string archiveError)
    {
        <div class="alert alert-danger">@archiveError</div>
    }

    <form asp-action="Archive" method="get" class="archive-controls module-filters">
        <div class="search-wrapper shadow-sm">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="search" placeholder="Search archived items..." />
        </div>
        <select class="form-select status-filter shadow-sm" name="type" onchange="this.form.submit()">
            <option value="All">All Types</option>
            <option value="Task">Task</option>
            <option value="Project">Project</option>
            <option value="Document">Document</option>
            <option value="Employee">Employee</option>
            <option value="User">User</option>
            <option value="LeaveRequest">LeaveRequest</option>
        </select>
    </form>

    <div class="archive-list">
        @if (!Model.Any())
        {
            <div class="archive-item-card">
                <div class="item-main-info">
                    <h6>No archived items found.</h6>
                </div>
            </div>
        }
        @foreach (var item in Model)
        {
            var daysElapsed = (int)Math.Floor((DateTime.UtcNow - item.DateArchived.ToUniversalTime()).TotalDays);
            var remainingDays = Math.Max(0, 30 - daysElapsed);
            var iconClass = item.Type switch
            {
                "Task" => "bi-clipboard-check",
                "Project" => "bi-folder2-open",
                "Document" => "bi-file-earmark-text",
                "Employee" => "bi-person-badge",
                "User" => "bi-person",
                _ => "bi-archive"
            };
            var badgeClass = item.Type switch
            {
                "Task" => "badge-task",
                "Project" => "badge-project",
                "Document" => "badge-document",
                _ => "badge-task"
            };
            <div class="archive-item-card">
                <div class="type-icon-wrapper">
                    <i class="bi @iconClass fs-5"></i>
                </div>
                <div class="item-main-info">
                    <div class="item-title-badge">
                        <h6>@item.Title</h6>
                        <span class="badge-soft @badgeClass">@item.Type</span>
                    </div>
                    <div class="item-subtext">
                        Archived by @item.ArchivedBy &bull; @item.DateArchived.ToString("MMM dd, yyyy")
                    </div>
                    <div class="item-reason-text">
                        Reason: @item.Reason
                    </div>
                </div>
                <div class="archive-actions">
                    <button type="button"
                            class="btn btn-archive-action btn-restore-outline open-restore-modal"
                            data-bs-toggle="modal"
                            data-bs-target="#restoreArchiveModal"
                            data-id="@item.Id">
                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                    </button>
                    <button type="button"
                            class="btn btn-archive-action btn-delete-outline open-delete-modal"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteArchiveModal"
                            data-id="@item.Id">
                        <i class="bi bi-trash"></i> Remove
                    </button>
                    <div class="auto-remove-text">Automatically removed in @remainingDays days</div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="restoreArchiveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered syncora-confirm-dialog">
        <div class="modal-content archive-modal-content syncora-confirm-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Restore Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="mb-3">Restore this archived item?</p>
                <form asp-action="Restore" method="post" id="restoreArchiveForm" class="d-flex justify-content-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restoreArchiveId" />
                    <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-save px-4">Confirm</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteArchiveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered syncora-confirm-dialog">
        <div class="modal-content archive-modal-content syncora-confirm-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Delete Permanently</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="mb-3">Delete this archived item permanently? This cannot be undone.</p>
                <form asp-action="Delete" method="post" id="deleteArchiveForm" class="d-flex justify-content-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteArchiveId" />
                    <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-save px-4">Confirm</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.open-restore-modal').forEach(function (button) {
            button.addEventListener('click', function () {
                document.getElementById('restoreArchiveId').value = button.getAttribute('data-id') || '';
            });
        });

        document.querySelectorAll('.open-delete-modal').forEach(function (button) {
            button.addEventListener('click', function () {
                document.getElementById('deleteArchiveId').value = button.getAttribute('data-id') || '';
            });
        });
    </script>
}
