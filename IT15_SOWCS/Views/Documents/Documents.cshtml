@model IT15_SOWCS.ViewModels.DocumentsPageViewModel
@{
    Layout = "_DocumentsLayout";
    ViewData["Title"] = "Documents";
}

@functions {
    private static string FormatSize(long sizeBytes)
    {
        const double kb = 1024;
        const double mb = kb * 1024;
        if (sizeBytes >= mb) return $"{sizeBytes / mb:0.0} MB";
        if (sizeBytes >= kb) return $"{sizeBytes / kb:0.0} KB";
        return $"{sizeBytes} B";
    }
}

<div class="docs-container">
    <div class="docs-header">
        <div class="docs-title">
            <h2>Documents</h2>
            <p>Upload and manage your documents</p>
        </div>
        <button type="button" class="btn btn-upload mb-0" data-bs-toggle="modal" data-bs-target="#uploadDocumentModal">
            <i class="bi bi-upload me-2"></i> Upload Document
        </button>
    </div>

    @if (TempData["DocumentsError"] is string documentsError)
    {
        <div class="alert alert-danger">@documentsError</div>
    }

    <form asp-action="Documents" method="get" class="filter-bar module-filters">
        <div class="search-wrapper shadow-sm">
            <i class="bi bi-search text-muted"></i>
            <input type="text" name="search" placeholder="Search documents..." value="@Model.Search">
        </div>
        <select class="form-select status-filter shadow-sm" name="category" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Category) || Model.Category == "All" ? "selected" : null)">All Categories</option>
            <option value="Policy" selected="@(Model.Category == "Policy" ? "selected" : null)">Policy</option>
            <option value="Other" selected="@(Model.Category == "Other" ? "selected" : null)">Other</option>
            <option value="Template" selected="@(Model.Category == "Template" ? "selected" : null)">Template</option>
        </select>
    </form>

    @if (Model.Documents.Count == 0)
    {
        <div class="empty-state-section text-center py-5 bg-white rounded-4 border">
            <h5 class="mb-2">No documents found</h5>
            <p class="text-muted mb-0">Upload a document to start.</p>
        </div>
    }
    else
    {
        <div class="doc-grid">
            @foreach (var doc in Model.Documents)
            {
                var statusClass = doc.status == "Approved"
                    ? "status-approved"
                    : doc.status == "Rejected"
                        ? "status-rejected"
                        : doc.status == "Pending"
                            ? "status-pending"
                            : "status-draft";
                <div class="doc-card">
                    <div class="dropdown doc-actions-dropdown">
                        <button class="btn btn-sm doc-actions-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Actions" aria-label="Actions">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="@doc.file_path" target="_blank">
                                    <i class="bi bi-eye me-2"></i>View
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@doc.file_path" download="@doc.file_name">
                                    <i class="bi bi-download me-2"></i>Download
                                </a>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#editDocumentModal-@doc.document_id">
                                    <i class="bi bi-pencil-square me-2"></i>Edit
                                </button>
                            </li>
                            <li>
                                <form asp-action="Delete" method="post" class="archive-confirm-form" data-archive-title="Archive Document" data-archive-message="Archive this document?">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="documentId" value="@doc.document_id" />
                                    <button type="submit" class="dropdown-item text-warning">
                                        <i class="bi bi-archive me-2"></i>Archive
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-start doc-main-row">
                        <div class="doc-icon-box">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div class="doc-info">
                            <h3 class="doc-name">@doc.title</h3>
                            <span class="doc-filename">@doc.file_name</span>
                            <div class="mt-2">
                                <span class="badge-status @statusClass">@doc.status</span>
                                <span class="badge-category">@doc.category</span>
                            </div>
                            @if (doc.status == "Rejected" && !string.IsNullOrWhiteSpace(doc.review_notes))
                            {
                                <div class="doc-feedback">Feedback: @doc.review_notes</div>
                            }
                        </div>
                    </div>
                    <div class="doc-footer pt-3">
                        <span>@FormatSize(doc.file_size_bytes)</span>
                        <span>@doc.uploaded_date.ToString("MMM d, yyyy")</span>
                    </div>
                </div>

                <div class="modal fade" id="editDocumentModal-@doc.document_id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content upload-modal">
                            <div class="modal-header border-0">
                                <h5 class="modal-title">Edit Document</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <form asp-action="Update" method="post" enctype="multipart/form-data">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="documentId" value="@doc.document_id" />

                                    <div class="mb-3">
                                        <label class="form-label">Title</label>
                                        <input type="text" class="form-control" name="title" value="@doc.title" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Category</label>
                                        <select class="form-select" name="category">
                                            <option value="Other" selected="@(doc.category == "Other" ? "selected" : null)">Other</option>
                                            <option value="Policy" selected="@(doc.category == "Policy" ? "selected" : null)">Policy</option>
                                            <option value="Template" selected="@(doc.category == "Template" ? "selected" : null)">Template</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Replace Document (Optional)</label>
                                        <input type="file"
                                               class="form-control"
                                               name="uploadedFile"
                                               accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.png" />
                                        <div class="form-text mt-1">Current file: @doc.file_name</div>
                                    </div>
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-upload-submit">Save Changes</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="uploadDocumentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content upload-modal">
            <div class="modal-header border-0">
                <h5 class="modal-title">Upload Document</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Upload" asp-controller="Documents" method="post" enctype="multipart/form-data" id="uploadDocumentForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" class="form-control" name="title" placeholder="Document title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="3" placeholder="Optional description"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" name="category">
                            <option value="Other" selected>Other</option>
                            <option value="Policy">Policy</option>
                            <option value="Template">Template</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">File</label>
                        <input type="file"
                               class="form-control"
                               name="uploadedFile"
                               accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.png"
                               required />
                    </div>
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" value="true" id="visibleToAllEmployees" name="visibleToAllEmployees" />
                        <label class="form-check-label" for="visibleToAllEmployees">
                            Make this document visible to all employees
                        </label>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-upload-submit">Upload</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

