@{
    Layout = "_EmployeesLayout";
    ViewData["Title"] = "Employees";
}

<div class="employees-container">
    <div class="emp-header">
        <h2>Employees</h2>
        <p>Manage employee records and information</p>
    </div>

    <div class="emp-controls">
        <div class="search-wrapper">
            <i class="bi bi-search"></i>
            <input type="text" class="search-input" placeholder="Search employees...">
        </div>
        <select class="dept-filter">
            <option>All Departments</option>
            <option>Admin</option>
            <option>HR</option>
            <option>Engineering</option>
        </select>
    </div>

    <div class="emp-table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Role</th>
                    <th>Leave Balance</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="avatar-circle">D</div>
                            <div class="user-meta">
                                <span class="name">degara03</span>
                                <span class="email">degara03@gmail.com</span>
                            </div>
                        </div>
                    </td>
                    <td>Admin</td>
                    <td>Manager</td>
                    <td><span class="badge bg-light text-secondary border">Employee</span></td>
                    <td>
                        <div class="leave-balance-row">
                            <span class="lb-a">12 A</span>
                            <span class="lb-s">10 S</span>
                            <span class="lb-p">5 P</span>
                        </div>
                    </td>
                    <td>
                        <button class="btn btn-link text-dark" data-bs-toggle="modal" data-bs-target="#editModal">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">Edit Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4">
                <div class="edit-user-preview d-flex align-items-center p-3 mb-4 rounded-3" style="background-color: #f8f9fa;">
                    <div class="avatar-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                         style="width: 56px; height: 56px; font-size: 1.2rem; border-radius: 50%;">
                        D
                    </div>
                    <div class="user-meta ms-3">
                        <div class="name fw-bold" style="font-size: 1.1rem; color: #333;">degara03</div>
                        <div class="email text-muted" style="font-size: 0.9rem;">degara03@gmail.com</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold small mb-1">Department</label>
                        <select class="form-select shadow-none">
                            <option selected>Admin</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small mb-1">Role</label>
                        <select class="form-select shadow-none">
                            <option selected>Employee</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small mb-1">Position</label>
                        <input type="text" class="form-control shadow-none" value="Manager">
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small mb-1">Phone</label>
                        <input type="text" class="form-control shadow-none" value="09548498965">
                    </div>
                </div>

                <div class="mt-4 pt-2 border-top">
                    <label class="form-label fw-semibold small mb-2">Leave Balances</label>
                    <div class="row g-3">
                        <div class="col-4">
                            <label class="text-muted extra-small d-block mb-1">Annual</label>
                            <input type="number" class="form-control shadow-none" value="12">
                        </div>
                        <div class="col-4">
                            <label class="text-muted extra-small d-block mb-1">Sick</label>
                            <input type="number" class="form-control shadow-none" value="10">
                        </div>
                        <div class="col-4">
                            <label class="text-muted extra-small d-block mb-1">Personal</label>
                            <input type="number" class="form-control shadow-none" value="5">
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-save px-4">Save Changes</button>
            </div>
        </div>
    </div>
</div>