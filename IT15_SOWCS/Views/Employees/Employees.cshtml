@model IT15_SOWCS.ViewModels.EmployeesPageViewModel
@{
    Layout = "_EmployeesLayout";
    ViewData["Title"] = "Employees";
}

<div class="employees-container">
    <div class="emp-header d-flex justify-content-between align-items-start">
        <div>
            <h2>Employees</h2>
            <p>Manage employee records and information</p>
        </div>
        <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
            <i class="bi bi-plus-lg me-2"></i> Add Employee
        </button>
    </div>

    @if (TempData["EmployeesError"] is string employeesError)
    {
        <div class="alert alert-danger">@employeesError</div>
    }

    <form asp-action="Employees" method="get" class="emp-controls module-filters d-flex gap-3">
        <div class="search-wrapper flex-grow-1">
            <i class="bi bi-search text-muted"></i>
            <input type="text" placeholder="Search employees..." name="search" value="@Model.Search">
        </div>
        <select class="form-select status-filter shadow-sm" name="department" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Department) || Model.Department == "All" ? "selected" : null)">All Departments</option>
            @foreach (var department in Model.Employees.Select(employee => employee.department).Distinct().OrderBy(item => item))
            {
                <option value="@department" selected="@(Model.Department == department ? "selected" : null)">@department</option>
            }
        </select>
    </form>

    <div class="emp-table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Role</th>
                    <th>Leave Balance</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No employees found.</td></tr>
                }
                @foreach (var employee in Model.Employees)
                {
                    var initials = string.Concat(employee.full_name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="avatar-circle">@initials</div>
                                <div class="user-meta">
                                    <span class="name">@employee.full_name</span>
                                    <span class="email">@employee.User?.Email</span>
                                </div>
                            </div>
                        </td>
                        <td>@employee.department</td>
                        <td>@employee.position</td>
                        <td><span class="badge bg-light text-secondary border">@employee.employee_role</span></td>
                        <td>
                            <div class="leave-balance-row">
                                <span class="lb-a">@employee.annual_leave_balance A</span>
                                <span class="lb-s">@employee.sick_leave_balance S</span>
                                <span class="lb-p">@employee.personal_leave_balance P</span>
                            </div>
                        </td>
                        <td class="text-end">
                            <details class="d-inline-block text-start">
                                <summary class="btn btn-sm btn-outline-secondary">Edit</summary>
                                <form asp-action="Update" method="post" class="border rounded-3 p-3 bg-light mt-2" style="min-width: 340px;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="employeeId" value="@employee.employee_id" />
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label class="form-label small">Department</label>
                                            <input class="form-control form-control-sm" name="department" value="@employee.department" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small">Role</label>
                                            <input class="form-control form-control-sm" name="employeeRole" value="@employee.employee_role" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small">Position</label>
                                            <input class="form-control form-control-sm" name="position" value="@employee.position" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small">Phone</label>
                                            <input class="form-control form-control-sm" name="contactNumber" value="@employee.contact_number" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Annual</label>
                                            <input class="form-control form-control-sm" type="number" step="0.5" name="annualLeave" value="@employee.annual_leave_balance" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Sick</label>
                                            <input class="form-control form-control-sm" type="number" step="0.5" name="sickLeave" value="@employee.sick_leave_balance" />
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small">Personal</label>
                                            <input class="form-control form-control-sm" type="number" step="0.5" name="personalLeave" value="@employee.personal_leave_balance" />
                                        </div>
                                    </div>
                                    <div class="form-check mt-2">
                                        <input class="form-check-input" type="checkbox" name="isActive" value="true" checked="@(employee.is_active ? "checked" : null)" />
                                        <label class="form-check-label">Active</label>
                                    </div>
                                    <div class="text-end mt-2">
                                        <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                    </div>
                                </form>
                            </details>
                            <form asp-action="Delete" method="post" class="d-inline-block ms-1" onsubmit="return confirm('Archive this employee record?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="employeeId" value="@employee.employee_id" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">Archive</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createEmployeeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">Add Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label small">User Account</label>
                        <select class="form-select" name="userId" required>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.Email</option>
                            }
                        </select>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small">Full Name</label>
                            <input class="form-control" name="fullName" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Department</label>
                            <input class="form-control" name="department" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Position</label>
                            <input class="form-control" name="position" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Contact</label>
                            <input class="form-control" name="contactNumber" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Role</label>
                            <input class="form-control" name="employeeRole" value="Employee" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Hire Date</label>
                            <input type="date" class="form-control" name="hireDate" />
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 pt-3">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Add Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

