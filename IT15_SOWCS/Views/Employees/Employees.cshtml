@model IT15_SOWCS.ViewModels.EmployeesPageViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<IT15_SOWCS.Models.Users> UserManager
@{
    Layout = "_EmployeesLayout";
    ViewData["Title"] = "Employees";
    var departmentOptions = new[] { "Human Resource", "Project Management", "Regular Employee" };
    var roleOptions = new[] { "Employee", "Manager", "HR manager" };
    var currentUser = await UserManager.GetUserAsync(User);
    var canArchive = string.Equals(currentUser?.Role, "superadmin", StringComparison.OrdinalIgnoreCase);
}

<div class="employees-container">
    <div class="emp-header d-flex justify-content-between align-items-start">
        <div>
            <h2>Employees</h2>
            <p>Manage employee records and information</p>
        </div>
        <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
            <i class="bi bi-plus-lg me-2"></i> Add Employee
        </button>
    </div>

    @if (TempData["EmployeesError"] is string employeesError)
    {
        <div class="alert alert-danger">@employeesError</div>
    }

    <form asp-action="Employees" method="get" class="emp-controls module-filters d-flex gap-3">
        <div class="search-wrapper flex-grow-1">
            <i class="bi bi-search text-muted"></i>
            <input type="text" placeholder="Search employees..." name="search" value="@Model.Search">
        </div>
        <select class="form-select status-filter shadow-sm" name="department" onchange="this.form.submit()">
            <option value="All" selected="@(string.IsNullOrWhiteSpace(Model.Department) || Model.Department == "All" ? "selected" : null)">All Departments</option>
            @foreach (var department in Model.Employees.Select(employee => employee.department).Distinct().OrderBy(item => item))
            {
                <option value="@department" selected="@(Model.Department == department ? "selected" : null)">@department</option>
            }
        </select>
    </form>

    <div class="emp-table-card">
        <table class="table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Role</th>
                    <th>Leave Balance</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No employees found.</td></tr>
                }
                @foreach (var employee in Model.Employees)
                {
                    var initials = string.Concat(employee.full_name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="avatar-circle">@initials</div>
                                <div class="user-meta">
                                    <span class="name">@employee.full_name</span>
                                    <span class="email">@employee.User?.Email</span>
                                </div>
                            </div>
                        </td>
                        <td>@employee.department</td>
                        <td>@employee.position</td>
                        <td><span class="badge bg-light text-secondary border">@employee.employee_role</span></td>
                        <td>
                            <div class="leave-balance-row">
                                <span class="lb-a">@employee.annual_leave_balance.ToString("0") A</span>
                                <span class="lb-s">@employee.sick_leave_balance.ToString("0") S</span>
                                <span class="lb-p">@employee.personal_leave_balance.ToString("0") P</span>
                            </div>
                        </td>
                        <td class="text-end">
                            <div class="dropdown d-inline-block ms-1 align-top">
                                <button class="btn btn-sm ellipsis-action-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Actions" aria-label="Actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#editEmployeeModal-@employee.employee_id"><i class="bi bi-pencil-square me-2"></i>Edit</button>
                                    </li>
                                    @if (canArchive)
                                    {
                                        <li>
                                            <form asp-action="Delete" method="post" class="archive-confirm-form" data-archive-title="Archive Employee" data-archive-message="Archive this employee record?">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="employeeId" value="@employee.employee_id" />
                                                <button type="submit" class="dropdown-item text-warning"><i class="bi bi-archive me-2"></i>Archive</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>

                }
            </tbody>
        </table>
    </div>
</div>

@foreach (var employee in Model.Employees)
{
    var initials = string.Concat(employee.full_name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(2));
    <div class="modal fade" id="editEmployeeModal-@employee.employee_id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content edit-employee-modal">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title">Edit Employee</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="employeeId" value="@employee.employee_id" />
                        <div class="edit-user-preview mb-3">
                            <div class="avatar-circle">@initials</div>
                            <div class="user-meta">
                                <span class="name">@employee.full_name</span>
                                <span class="email">@employee.User?.Email</span>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="modal-label">Department</label>
                                <select class="form-select" name="department">
                                    @foreach (var dept in departmentOptions)
                                    {
                                        <option value="@dept" selected="@(employee.department == dept ? "selected" : null)">@dept</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="modal-label">Role</label>
                                <select class="form-select" name="employeeRole">
                                    @foreach (var role in roleOptions)
                                    {
                                        <option value="@role" selected="@(employee.employee_role == role ? "selected" : null)">@role</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="modal-label">Position</label>
                                <input class="form-control" name="position" value="@employee.position" />
                            </div>
                            <div class="col-6">
                                <label class="modal-label">Phone</label>
                                <input class="form-control" name="contactNumber" value="@employee.contact_number" />
                            </div>
                        </div>

                        <hr class="my-3" />
                        <label class="modal-label d-block mb-2">Leave Balances</label>
                        <div class="row g-3">
                            <div class="col-4">
                                <span class="text-muted-small">Annual</span>
                                <input class="form-control" type="number" step="1" min="0" name="annualLeave" value="@employee.annual_leave_balance.ToString("0")" />
                            </div>
                            <div class="col-4">
                                <span class="text-muted-small">Sick</span>
                                <input class="form-control" type="number" step="1" min="0" name="sickLeave" value="@employee.sick_leave_balance.ToString("0")" />
                            </div>
                            <div class="col-4">
                                <span class="text-muted-small">Personal</span>
                                <input class="form-control" type="number" step="1" min="0" name="personalLeave" value="@employee.personal_leave_balance.ToString("0")" />
                            </div>
                        </div>

                        <input type="hidden" name="isActive" value="@(employee.is_active ? "true" : "false")" />
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-save px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="createEmployeeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="font-size: 1.25rem;">Add Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label small">User Account</label>
                        <select class="form-select" name="userId" required>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.Email</option>
                            }
                        </select>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small">Full Name</label>
                            <input class="form-control" name="fullName" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Department</label>
                            <select class="form-select" name="department" required>
                                @foreach (var dept in departmentOptions)
                                {
                                    <option value="@dept">@dept</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Position</label>
                            <input class="form-control" name="position" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Contact</label>
                            <input class="form-control" name="contactNumber" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Role</label>
                            <select class="form-select" name="employeeRole" required>
                                @foreach (var role in roleOptions)
                                {
                                    <option value="@role" selected="@(role == "Employee" ? "selected" : null)">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Hire Date</label>
                            <input type="date" class="form-control" name="hireDate" />
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 pt-3">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Add Employee</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



