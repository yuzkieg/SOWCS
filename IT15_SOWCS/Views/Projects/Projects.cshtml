@{
    ViewData["Title"] = "Projects";
    Layout = "_ProjectsLayout";
}

<div class="projects-container">
    <div class="projects-header">
        <div class="projects-title">
            <h2>Projects</h2>
            <p>Manage and track your team projects</p>
        </div>
        <button class="btn btn-create" data-bs-toggle="modal" data-bs-target="#createProjectModal">
            <i class="bi bi-plus-lg me-2"></i> Create Project
        </button>

        <div class="modal fade" id="createProjectModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Create Project</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body pt-3">
                        <form id="createProjectForm">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Project Name</label>
                                <input type="text" class="form-control custom-input" placeholder="e.g. Website Redesign">
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Description</label>
                                <textarea class="form-control custom-input" rows="3" placeholder="Briefly describe the project goals..."></textarea>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Status</label>
                                    <select class="form-select custom-input">
                                        <option selected>Planning</option>
                                        <option>Active</option>
                                        <option>On Hold</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted">Priority</label>
                                    <select class="form-select custom-input">
                                        <option>Low</option>
                                        <option selected>Medium</option>
                                        <option>High</option>
                                        <option>Urgent</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted">Team Members</label>
                                <select class="form-select custom-input" multiple>
                                    <option>John Doe</option>
                                    <option>Jane Smith</option>
                                    <option>Alex Rivera</option>
                                    <option>Sarah Connor</option>
                                </select>
                                <div class="form-text mt-1" style="font-size: 0.75rem;">Hold Ctrl/Cmd to select multiple members.</div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-save px-4">Create Project</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-9">
            <div class="search-wrapper shadow-sm">
                <i class="bi bi-search text-muted"></i>
                <input type="text" placeholder="Search projects...">
            </div>
        </div>
        <div class="col-md-3">
            <select class="status-filter shadow-sm">
                <option selected>All Status</option>
                <option>Active</option>
                <option>Completed</option>
            </select>
        </div>
    </div>

    <div class="empty-state-section">
        <div class="empty-icon-box">
            <i class="bi bi-folder2-open fs-1"></i>
        </div>
        <h4 class="empty-state-title">No projects found</h4>
        <p class="empty-state-text">You haven't been assigned to any projects yet</p>
    </div>
</div>