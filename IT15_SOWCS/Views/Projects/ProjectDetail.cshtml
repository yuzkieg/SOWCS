<div class="modal fade" id="editTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Edit Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-controller="Tasks" asp-action="Update" method="post" id="editTaskForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" id="editTaskId" />
                    <input type="hidden" name="status" id="editTaskStatus" />
                    <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task Title</label>
                        <input name="title" id="editTaskTitle" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" id="editTaskDescription" class="form-control custom-input" rows="3"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Assign To</label>
                            <select name="employeeId" id="editTaskEmployeeId" class="form-select custom-input" required>
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <option value="@member.employee_id">@member.full_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Priority</label>
                            <select name="priority" id="editTaskPriority" class="form-select custom-input" required>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input type="date" name="dueDate" id="editTaskDueDate" class="form-control custom-input" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-controller="Tasks" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Project.project_id" />
                    <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                    <input type="hidden" name="status" value="Pending" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Task Title</label>
                        <input name="title" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Description</label>
                        <textarea name="description" class="form-control custom-input" rows="3"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Assign To</label>
                            <select name="employeeId" class="form-select custom-input" required>
                                <option value="" selected disabled>Select member</option>
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <option value="@member.employee_id">@member.full_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Priority</label>
                            <select name="priority" class="form-select custom-input">
                                <option>Low</option>
                                <option selected>Medium</option>
                                <option>High</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Due Date</label>
                        <input type="date" name="dueDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control custom-input" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function showActionToast(message) {
        const existing = document.getElementById('projectDetailActionToast');
        if (existing) {
            existing.remove();
        }

        const toast = document.createElement('div');
        toast.id = 'projectDetailActionToast';
        toast.className = 'syncora-toast';
        toast.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + message;
        document.body.appendChild(toast);

        setTimeout(function () {
            toast.remove();
        }, 3000);
    }

    function refreshLaneCountsAndProgress() {
        document.querySelectorAll('.task-lane').forEach(function (lane) {
            const count = lane.querySelectorAll('.task-card-mini').length;
            const countNode = lane.querySelector('.lane-title span:last-child');
            if (countNode) {
                countNode.textContent = '(' + count + ')';
            }
        });

        const total = document.querySelectorAll('.task-card-mini').length;
        const completedLane = document.querySelector('.task-lane[data-status="Completed"]');
        const completed = completedLane ? completedLane.querySelectorAll('.task-card-mini').length : 0;
        const percent = total === 0 ? 0 : Math.round((completed * 100) / total);
        const fill = document.querySelector('.progress-card .project-progress-fill');
        const label = document.querySelector('.progress-card h4');
        if (fill) {
            fill.style.width = percent + '%';
        }
        if (label) {
            label.textContent = percent + '%';
        }
    }

    function enableTaskDragDrop() {
        const tokenInput = document.querySelector('#taskMoveTokenForm input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : '';
        const moveUrl = '@Url.Action("Move", "Tasks")';
        const redirectProjectId = '@Model.Project.project_id';

        document.querySelectorAll('.task-card-mini').forEach(function (card) {
            card.setAttribute('draggable', 'true');
            card.addEventListener('dragstart', function (event) {
                card.classList.add('is-dragging');
                event.dataTransfer.setData('text/plain', 'moving');
            });
            card.addEventListener('dragend', function () {
                card.classList.remove('is-dragging');
            });
        });

        document.querySelectorAll('.task-lane').forEach(function (lane) {
            lane.addEventListener('dragover', function (event) {
                event.preventDefault();
                lane.classList.add('lane-drop-active');
            });

            lane.addEventListener('dragleave', function () {
                lane.classList.remove('lane-drop-active');
            });

            lane.addEventListener('drop', async function (event) {
                event.preventDefault();
                lane.classList.remove('lane-drop-active');

                const draggingCard = document.querySelector('.task-card-mini.is-dragging');
                if (!draggingCard) {
                    return;
                }

                const taskIdInput = draggingCard.querySelector('input[name="taskId"]');
                const taskId = taskIdInput ? taskIdInput.value : '';
                const targetStatus = lane.getAttribute('data-status') || 'Pending';
                const sourceLane = draggingCard.closest('.task-lane');
                const sourceStatus = sourceLane ? sourceLane.getAttribute('data-status') : '';

                if (!taskId || sourceStatus === targetStatus) {
                    return;
                }

                const body = new URLSearchParams();
                body.append('taskId', taskId);
                body.append('status', targetStatus);
                body.append('redirectProjectId', redirectProjectId);

                const response = await fetch(moveUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body.toString()
                });

                if (!response.ok) {
                    showActionToast('Failed to move task.');
                    return;
                }

                lane.appendChild(draggingCard);
                refreshLaneCountsAndProgress();

                try {
                    const payload = await response.json();
                    showActionToast(payload.message || 'Task moved successfully.');
                } catch {
                    showActionToast('Task moved successfully.');
                }
            });
        });
    }

    document.querySelectorAll('.open-edit-task-modal').forEach(function (button) {
        button.addEventListener('click', function () {
            document.getElementById('editTaskId').value = button.getAttribute('data-task-id') || '';
            document.getElementById('editTaskTitle').value = button.getAttribute('data-title') || '';
            document.getElementById('editTaskDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editTaskEmployeeId').value = button.getAttribute('data-employee-id') || '';
            document.getElementById('editTaskPriority').value = button.getAttribute('data-priority') || 'Medium';
            document.getElementById('editTaskDueDate').value = button.getAttribute('data-due-date') || '';
            document.getElementById('editTaskStatus').value = button.getAttribute('data-status') || 'Pending';
        });
    });

    enableTaskDragDrop();
</script>

