<div class="modal fade" id="editTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Edit Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-controller="Tasks" asp-action="Update" method="post" id="editTaskForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" id="editTaskId" />
                    <input type="hidden" name="status" id="editTaskStatus" />
                    <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task Title</label>
                        <input name="title" id="editTaskTitle" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" id="editTaskDescription" class="form-control custom-input" rows="3"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Assign To</label>
                            <select name="employeeId" id="editTaskEmployeeId" class="form-select custom-input" required>
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <option value="@member.employee_id">@member.full_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Priority</label>
                            <select name="priority" id="editTaskPriority" class="form-select custom-input" required>
                                <option value="Low">Low</option>
                                <option value="Medium">Medium</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input type="date" name="dueDate" id="editTaskDueDate" class="form-control custom-input" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Create Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <form asp-controller="Tasks" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Project.project_id" />
                    <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                    <input type="hidden" name="status" value="Pending" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Task Title</label>
                        <input name="title" class="form-control custom-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Description</label>
                        <textarea name="description" class="form-control custom-input" rows="3"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Assign To</label>
                            <select name="employeeId" class="form-select custom-input" required>
                                <option value="" selected disabled>Select member</option>
                                @foreach (var member in Model.TeamMembers)
                                {
                                    <option value="@member.employee_id">@member.full_name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold text-muted">Priority</label>
                            <select name="priority" class="form-select custom-input">
                                <option>Low</option>
                                <option selected>Medium</option>
                                <option>High</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Due Date</label>
                        <input type="date" name="dueDate" class="form-control custom-input" required />
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-cancel px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-save px-4">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.open-edit-task-modal').forEach(function (button) {
        button.addEventListener('click', function () {
            document.getElementById('editTaskId').value = button.getAttribute('data-task-id') || '';
            document.getElementById('editTaskTitle').value = button.getAttribute('data-title') || '';
            document.getElementById('editTaskDescription').value = button.getAttribute('data-description') || '';
            document.getElementById('editTaskEmployeeId').value = button.getAttribute('data-employee-id') || '';
            document.getElementById('editTaskPriority').value = button.getAttribute('data-priority') || 'Medium';
            document.getElementById('editTaskDueDate').value = button.getAttribute('data-due-date') || '';
            document.getElementById('editTaskStatus').value = button.getAttribute('data-status') || 'Pending';
        });
    });
</script>
