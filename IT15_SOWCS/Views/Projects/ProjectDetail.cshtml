                                <span class="task-assignee">@(string.IsNullOrWhiteSpace(task.assigned_name) ? "?" : task.assigned_name[0])</span>
                            </div>
                        </div>
                    }
                </div>
                <div class="task-lane">
                    <div class="lane-title"><span class="lane-pill lane-review">Review</span> <span>(@reviewTasks.Count)</span></div>
                    @foreach (var task in reviewTasks)
