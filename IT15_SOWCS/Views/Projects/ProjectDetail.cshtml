@model IT15_SOWCS.ViewModels.ProjectDetailViewModel
@{
    Layout = "_ProjectsLayout";
    ViewData["Title"] = "Project Detail";

    var todoTasks = Model.Tasks.Where(task => task.status == "Pending").ToList();
    var inProgressTasks = Model.Tasks.Where(task => task.status == "In Progress").ToList();
    var reviewTasks = Model.Tasks.Where(task => task.status == "Review").ToList();
    var completedTasks = Model.Tasks.Where(task => task.status == "Completed").ToList();
    var totalTaskCount = Model.Tasks.Count;
    var completedTaskCount = completedTasks.Count;
    var progressPercent = totalTaskCount == 0 ? 0 : (int)Math.Round((completedTaskCount * 100.0) / totalTaskCount);
}

<div class="project-detail-container">
    <div class="project-detail-header-row">
        <a asp-action="Projects" class="project-back-link"><i class="bi bi-arrow-left"></i></a>
        <div class="project-detail-headings">
            <h2>@Model.Project.name</h2>
            <p>@Model.Project.description</p>
        </div>
        <div class="project-detail-badges">
            <span class="status-pill">@Model.Project.status</span>
            <span class="priority-pill @(
                Model.Project.priority == "High" ? "priority-high" :
                Model.Project.priority == "Medium" ? "priority-medium" :
                Model.Project.priority == "Urgent" ? "priority-critical" : "priority-low"
            )">@Model.Project.priority</span>
        </div>
    </div>

    <div class="project-detail-stats">
        <div class="detail-stat-card">
            <div class="detail-stat-icon icon-blue"><i class="bi bi-clipboard-check"></i></div>
            <div><h4>@Model.Tasks.Count</h4><p>Total Tasks</p></div>
        </div>
        <div class="detail-stat-card">
            <div class="detail-stat-icon icon-green"><i class="bi bi-people"></i></div>
            <div><h4>@Model.TeamMembers.Count</h4><p>Team Members</p></div>
        </div>
        <div class="detail-stat-card">
            <div class="detail-stat-icon icon-purple"><i class="bi bi-calendar-event"></i></div>
            <div><h4>@Model.Project.due_date.ToString("MMM d")</h4><p>Due Date</p></div>
        </div>
        <div class="detail-stat-card progress-card">
            <p>Progress</p>
            <div class="project-progress-track">
                <div class="project-progress-fill" style="width:@progressPercent%;"></div>
            </div>
            <h4>@progressPercent%</h4>
        </div>
    </div>

    <div class="project-detail-body">
        <div class="team-panel">
            <div class="team-panel-header">
                <h5>Team Members</h5>
            </div>
            @if (Model.TeamMembers.Count == 0)
            {
                <div class="text-muted small">No team members assigned.</div>
            }
            else
            {
                @foreach (var member in Model.TeamMembers)
                {
                    var initials = string.Concat(member.full_name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(part => char.ToUpperInvariant(part[0])).Take(1));
                    <div class="team-member-row">
                        <div class="member-avatar">@initials</div>
                        <div>
                            <div class="member-name">@member.full_name</div>
                            <div class="member-role">@member.position</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="tasks-panel">
            <div class="tasks-panel-header">
                <h5>Tasks</h5>
                <button type="button" class="btn btn-create btn-sm" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                    <i class="bi bi-plus-lg me-1"></i> Add Task
                </button>
            </div>
            <div class="task-lanes">
                <div class="task-lane">
                    <div class="lane-title"><span class="lane-pill lane-todo">To Do</span> <span>(@todoTasks.Count)</span></div>
                    @foreach (var task in todoTasks)
                    {
                        <div class="task-card-mini">
                            <div class="dropdown task-menu-dropdown">
                                <button class="btn task-card-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Task actions">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="Tasks" asp-action="Move" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.task_id" />
                                            <input type="hidden" name="status" value="In Progress" />
                                            <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                                            <button type="submit" class="dropdown-item">Move to In Progress</button>
                                        </form>
                                    </li>
                                    <li>
                                        <form asp-controller="Tasks" asp-action="Move" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.task_id" />
                                            <input type="hidden" name="status" value="Review" />
                                            <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                                            <button type="submit" class="dropdown-item">Move to Review</button>
                                        </form>
                                    </li>
                                    <li>
                                        <form asp-controller="Tasks" asp-action="Move" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.task_id" />
                                            <input type="hidden" name="status" value="Completed" />
                                            <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                                            <button type="submit" class="dropdown-item">Mark Complete</button>
                                        </form>
                                    </li>
                                    <li>
                                        <button type="button"
                                                class="dropdown-item open-edit-task-modal"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editTaskModal"
                                                data-task-id="@task.task_id"
                                                data-title="@task.title"
                                                data-description="@task.description"
                                                data-employee-id="@task.employee_id"
                                                data-priority="@task.priority"
                                                data-due-date="@task.due_date.ToString("yyyy-MM-dd")"
                                                data-status="@task.status">Edit</button>
                                    </li>
                                    <li>
                                        <form asp-controller="Tasks" asp-action="Delete" method="post" onsubmit="return confirm('Archive this task?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.task_id" />
                                            <input type="hidden" name="redirectProjectId" value="@Model.Project.project_id" />
                                            <button type="submit" class="dropdown-item dropdown-item-danger">Archive</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                            <div class="task-card-title">@task.title</div>
                            <div class="task-card-meta">
                                <span class="priority-pill @(
                                    task.priority == "High" ? "priority-high" :
                                    task.priority == "Medium" ? "priority-medium" :
                                    task.priority == "Urgent" ? "priority-critical" : "priority-low"
                                )">@task.priority</span>
                                <span class="task-assignee">@(string.IsNullOrWhiteSpace(task.assigned_name) ? "?" : task.assigned_name[0])</span>
                            </div>
                        </div>
                    }
                </div>
                <div class="task-lane">
                    <div class="lane-title"><span class="lane-pill lane-inprogress">In Progress</span> <span>(@inProgressTasks.Count)</span></div>
